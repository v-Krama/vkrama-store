{
  "name": "vkrama",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev dist",
    "deploy": "astro build && wrangler pages deploy dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute vkrama-db --remote --file=./src/db/migrations/0000_public_maginty.sql",
    "db:seed": "wrangler d1 execute vkrama-db --remote --file=./src/db/seed.sql",
    "types": "wrangler types",
    "cf:tail": "wrangler tail",
    "cf:logs": "wrangler pages deployment list --project-name vkrama"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.2.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/tailwind": "^6.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@stripe/react-stripe-js": "^3.6.0",
    "@stripe/stripe-js": "^6.1.0",
    "astro": "^5.6.0",
    "drizzle-orm": "^0.41.0",
    "jose": "^6.0.0",
    "nanoid": "^5.1.0",
    "react": "^19.1.0",
    "react-admin": "^5.14.7",
    "react-dom": "^19.1.0",
    "stripe": "^18.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-kit": "^0.30.6",
    "typescript": "^5.8.0",
    "wrangler": "^4.100.0"
  }
}
