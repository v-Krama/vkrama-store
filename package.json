{
  "name": "vkrama-store",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev dist",
    "deploy": "astro build && wrangler pages deploy dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply vkrama-db",
    "db:seed": "wrangler d1 execute vkrama-db --file=./src/db/seed.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.2.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/tailwind": "^6.0.0",
    "@stripe/react-stripe-js": "^3.6.0",
    "@stripe/stripe-js": "^6.1.0",
    "astro": "^5.6.0",
    "drizzle-orm": "^0.41.0",
    "hash-wasm": "^4.12.0",
    "jose": "^6.0.0",
    "nanoid": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^18.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-kit": "^0.30.6",
    "typescript": "^5.8.0",
    "wrangler": "^4.7.0"
  }
}
