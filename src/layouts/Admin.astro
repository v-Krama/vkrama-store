---
import '../styles/global.css'
import AdminSidebar from '../components/layout/AdminSidebar.astro'

export interface Props {
  title: string
}

const { title } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — vkrama Admin</title>
  </head>
  <body>
    <div class="flex h-screen overflow-hidden">
      <AdminSidebar />
      <div class="flex-1 overflow-y-auto bg-gray-50">
        <header class="sticky top-0 z-10 bg-white border-b border-gray-200 px-6 py-4">
          <div class="flex items-center justify-between">
            <h1 class="text-xl font-semibold text-gray-900">{title}</h1>
            <div class="flex items-center gap-3">
              <span class="text-sm text-gray-500" id="admin-email"></span>
              <a href="/admin/login" class="btn-secondary btn-sm" id="logout-btn">Logout</a>
            </div>
          </div>
        </header>
        <main class="p-6">
          <slot />
        </main>
      </div>
    </div>
    <script>
      const email = localStorage.getItem('vkrama_admin_email')
      const token = localStorage.getItem('vkrama_admin_token')
      const emailEl = document.getElementById('admin-email')
      const logoutBtn = document.getElementById('logout-btn')
      if (!token) {
        window.location.href = '/admin/login'
      } else {
        if (emailEl) emailEl.textContent = email || 'Admin'
      }
      if (logoutBtn) {
        logoutBtn.addEventListener('click', (e) => {
          e.preventDefault()
          localStorage.removeItem('vkrama_admin_token')
          localStorage.removeItem('vkrama_admin_email')
          window.location.href = '/admin/login'
        })
      }
    </script>
  </body>
</html>
