---
import '../styles/global.css'
import AdminSidebar from '../components/layout/AdminSidebar.astro'

export interface Props {
  title: string
}

const { title } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — vkrama Admin</title>
  </head>
  <body class="bg-surface-50">
    <div class="flex h-screen overflow-hidden">
      <AdminSidebar />
      <div class="flex-1 flex flex-col overflow-hidden">
        <header class="sticky top-0 z-10 bg-white border-b border-surface-200 px-6 py-3">
          <div class="flex items-center justify-between">
            <h1 class="text-lg font-semibold text-surface-900">{title}</h1>
            <div class="flex items-center gap-3">
              <span class="text-sm text-surface-400" id="admin-email"></span>
              <span class="w-px h-4 bg-surface-200"></span>
              <a href="/" class="text-sm text-surface-500 hover:text-surface-700 transition-colors" target="_blank">
                View Store
              </a>
              <button id="logout-btn" class="btn-ghost btn-sm text-red-600 hover:text-red-700">Logout</button>
            </div>
          </div>
        </header>
        <main class="flex-1 overflow-y-auto p-6">
          <slot />
        </main>
      </div>
    </div>
    <script>
      const email = localStorage.getItem('vkrama_admin_email')
      const token = localStorage.getItem('vkrama_admin_token')
      const emailEl = document.getElementById('admin-email')
      const logoutBtn = document.getElementById('logout-btn')
      if (!token) {
        window.location.href = '/admin/login'
      } else {
        if (emailEl) emailEl.textContent = email || 'Admin'
      }
      if (logoutBtn) {
        logoutBtn.addEventListener('click', (e) => {
          e.preventDefault()
          localStorage.removeItem('vkrama_admin_token')
          localStorage.removeItem('vkrama_admin_email')
          window.location.href = '/admin/login'
        })
      }
    </script>
  </body>
</html>
