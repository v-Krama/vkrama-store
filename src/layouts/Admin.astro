---
import '../styles/global.css'
import AdminSidebar from '../components/layout/AdminSidebar.astro'

export interface Props {
  title: string
}

const { title } = Astro.props
const slug = (Astro.params.slug as string)
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — vkrama Admin</title>
  </head>
  <body class="bg-surface-50">
    <div class="flex h-screen overflow-hidden">
      <AdminSidebar slug={slug} />
      <div class="flex-1 flex flex-col overflow-hidden">
        <header class="sticky top-0 z-10 bg-white border-b border-surface-200 px-6 py-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h1 class="text-lg font-semibold text-surface-900">{title}</h1>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-sm text-surface-500" id="admin-email"></span>
              <span class="w-px h-4 bg-surface-200"></span>
              <a href="/" class="text-sm text-surface-400 hover:text-surface-600 transition-colors" target="_blank">
                <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Store
              </a>
              <button id="logout-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Logout
              </button>
            </div>
          </div>
        </header>
        <main class="flex-1 overflow-y-auto p-6">
          <slot />
        </main>
      </div>
    </div>
    <div id="toast-container" class="toast-container"></div>
      <script>
        const _slug = window.location.pathname.split('/')[2]
        const email = localStorage.getItem('vkrama_admin_email')
        const token = localStorage.getItem('vkrama_admin_token')
        const emailEl = document.getElementById('admin-email')
        const logoutBtn = document.getElementById('logout-btn')

        function showToast(message, type = 'success') {
          const container = document.getElementById('toast-container')
          if (!container) return
          const toast = document.createElement('div')
          toast.className = `toast-${type}`
          toast.textContent = message
          container.appendChild(toast)
          setTimeout(() => {
            toast.style.opacity = '0'
            toast.style.transition = 'opacity 0.3s'
            setTimeout(() => toast.remove(), 300)
          }, 3000)
        }
        ;(window as any).showToast = showToast

        async function checkToken() {
          if (!token) {
            window.location.href = '/admin/' + _slug + '/login'
            return
          }
          try {
            const res = await fetch('/api/admin/stats', {
              headers: { Authorization: `Bearer ${token}` },
              signal: AbortSignal.timeout(5000),
            })
            if (res.status === 401) {
              localStorage.removeItem('vkrama_admin_token')
              localStorage.removeItem('vkrama_admin_email')
              window.location.href = '/admin/' + _slug + '/login'
            }
          } catch {
            // Silent fail - token might still be valid
          }
          if (emailEl) emailEl.textContent = email || 'Admin'
        }

        if (logoutBtn) {
          logoutBtn.addEventListener('click', async (e) => {
            e.preventDefault()
            if (token) {
              await fetch('/api/admin/logout', {
                method: 'POST',
                headers: { Authorization: `Bearer ${token}` },
              }).catch(() => {})
            }
            localStorage.removeItem('vkrama_admin_token')
            localStorage.removeItem('vkrama_admin_email')
            window.location.href = '/admin/' + _slug + '/login'
          })
        }

        checkToken()
      </script>
  </body>
</html>
