---
const { pathname } = Astro.url
export interface Props {
  categories?: Array<{ id: string; name: string; slug: string }>
}
const { categories = [] } = Astro.props
---

<header id="site-header" class="sticky top-0 z-50 transition-all duration-500">
  <div id="header-inner" class="transition-all duration-500">
    <div class="container-page">
      <div class="flex items-center justify-between h-16 md:h-20">
        <div class="flex items-center gap-6 lg:gap-10">
          <button id="mobile-menu-btn" class="md:hidden btn-ghost btn-icon -ml-2" aria-label="Menu">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <a href="/" class="flex items-center shrink-0 group">
            <img src="/logo.svg" alt="vkrama" class="h-8 md:h-10 w-auto transition-transform duration-300 group-hover:scale-105" />
          </a>
          <nav class="hidden md:flex items-center gap-1">
            <a href="/products" class="nav-link">Products</a>
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Categories
                <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 mt-2 w-56 rounded-2xl bg-white shadow-2xl border border-surface-100 p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0">
                {categories.map((cat) => (
                  <a href={`/products?category=${cat.slug}`} class="flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm font-medium text-surface-600 hover:bg-surface-50 hover:text-surface-900 transition-all">{cat.name}</a>
                ))}
              </div>
            </div>
          </nav>
        </div>
        <div class="flex items-center gap-1.5 md:gap-2">
          <button id="search-btn" class="btn-icon btn-ghost relative group" aria-label="Search">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span class="hidden md:block absolute -bottom-8 left-1/2 -translate-x-1/2 bg-surface-900 text-white text-2xs px-2 py-1 rounded-md whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Search (Ctrl+K)</span>
          </button>
          <a id="account-link" href="/account/orders" class="btn-icon btn-ghost relative group hidden sm:flex" aria-label="My Account">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="hidden md:block absolute -bottom-8 left-1/2 -translate-x-1/2 bg-surface-900 text-white text-2xs px-2 py-1 rounded-md whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Account</span>
          </a>
          <a id="login-link" href="/auth/login" class="btn-icon btn-ghost relative group hidden sm:flex" aria-label="Sign In">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
            <span class="hidden md:block absolute -bottom-8 left-1/2 -translate-x-1/2 bg-surface-900 text-white text-2xs px-2 py-1 rounded-md whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Sign In</span>
          </a>
          <button id="cart-btn" class="btn-icon btn-ghost relative group" aria-label="Cart">
            <div id="cart-icon-wrap" class="relative">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              <span id="cart-count" class="absolute -top-1.5 -right-1.5 bg-accent-500 text-white text-2xs font-bold rounded-full h-4.5 min-w-[1.125rem] px-1 flex items-center justify-center hidden shadow-sm animate-scale-in">0</span>
            </div>
            <span class="hidden md:block absolute -bottom-8 left-1/2 -translate-x-1/2 bg-surface-900 text-white text-2xs px-2 py-1 rounded-md whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Cart</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 z-50 hidden">
    <div id="mobile-menu-bg" class="absolute inset-0 bg-surface-900/50 backdrop-blur-sm"></div>
    <div class="absolute left-0 top-0 bottom-0 w-72 max-w-[85vw] bg-white shadow-2xl animate-slide-in-right">
      <div class="flex items-center justify-between p-4 border-b border-surface-100">
        <img src="/logo.svg" alt="vkrama" class="h-7 w-auto" />
        <button id="mobile-menu-close" class="btn-ghost btn-icon" aria-label="Close">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="p-4 space-y-1 overflow-y-auto h-[calc(100%-4rem)]">
        <a href="/" class="flex items-center gap-3 px-3.5 py-3 rounded-xl text-sm font-medium text-surface-700 hover:bg-surface-50 transition-all">Home</a>
        <a href="/products" class="flex items-center gap-3 px-3.5 py-3 rounded-xl text-sm font-medium text-surface-700 hover:bg-surface-50 transition-all">Products</a>
        <div class="pl-3 ml-3 border-l-2 border-surface-100 space-y-1">
          {categories.map((cat) => (
            <a href={`/products?category=${cat.slug}`} class="flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-surface-600 hover:bg-surface-50 transition-all">{cat.name}</a>
          ))}
        </div>
        <hr class="my-3 border-surface-100" />
        <a id="mobile-account-link" href="/account/orders" class="flex items-center gap-3 px-3.5 py-3 rounded-xl text-sm font-medium text-surface-700 hover:bg-surface-50 transition-all">
          <svg class="h-5 w-5 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          My Account
        </a>
        <a href="/account/wishlist" class="flex items-center gap-3 px-3.5 py-3 rounded-xl text-sm font-medium text-surface-700 hover:bg-surface-50 transition-all">
          <svg class="h-5 w-5 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          My Wishlist
        </a>
        <a id="mobile-login-link" href="/auth/login" class="flex items-center gap-3 px-3.5 py-3 rounded-xl text-sm font-medium text-surface-700 hover:bg-surface-50 transition-all">
          <svg class="h-5 w-5 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          Sign In
        </a>
      </nav>
    </div>
  </div>

  <div id="search-overlay" class="hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-surface-900/60 backdrop-blur-md" id="search-overlay-bg"></div>
    <div class="relative max-w-2xl mx-auto px-4 pt-[15vh]">
      <div class="bg-white rounded-2xl shadow-2xl border border-surface-100 p-5 animate-scale-in">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" id="search-input" placeholder="Search products..." class="w-full pl-12 pr-4 py-3.5 text-base bg-surface-50 border-0 rounded-xl focus:ring-2 focus:ring-brand-500/30 focus:bg-white transition-all outline-none" autofocus />
          <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:inline-flex items-center px-2 py-1 text-2xs font-medium text-surface-400 bg-surface-100 rounded-md border border-surface-200">ESC</kbd>
        </div>
        <div id="search-results" class="mt-4 hidden"><div class="divide-y divide-surface-100" id="search-results-list"></div></div>
        <div id="search-empty" class="text-center py-12 text-surface-400">
          <svg class="w-10 h-10 mx-auto mb-3 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <p class="text-sm">Start typing to search products...</p>
        </div>
        <div id="search-no-results" class="hidden text-center py-12 text-surface-400">
          <svg class="w-10 h-10 mx-auto mb-3 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-sm">No results found</p>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply px-3.5 py-2.5 text-sm font-medium rounded-xl transition-all duration-200;
    color: theme('colors.surface.600');
  }
  .nav-link:hover {
    color: theme('colors.surface.900');
    background: theme('colors.surface.50');
  }
  #site-header.scrolled #header-inner {
    @apply bg-white/80 backdrop-blur-xl border-b border-surface-200/50 shadow-sm;
  }
  #site-header:not(.scrolled) #header-inner {
    @apply bg-white border-b border-surface-200/50;
  }
  #cart-count { height: 1.125rem; }
  .cart-bounce { animation: cartBounce 0.3s ease-out; }
  @keyframes cartBounce { 0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); } }
</style>

<script>
  document.getElementById('cart-btn')?.addEventListener('click', () => window.dispatchEvent(new CustomEvent('open-cart')))

  const mobileBtn = document.getElementById('mobile-menu-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  const mobileBg = document.getElementById('mobile-menu-bg')
  const mobileClose = document.getElementById('mobile-menu-close')
  function openMobile() { mobileMenu?.classList.remove('hidden'); document.body.style.overflow = 'hidden' }
  function closeMobile() { mobileMenu?.classList.add('hidden'); document.body.style.overflow = '' }
  mobileBtn?.addEventListener('click', openMobile)
  mobileBg?.addEventListener('click', closeMobile)
  mobileClose?.addEventListener('click', closeMobile)
  document.querySelectorAll('#mobile-menu a').forEach(l => l.addEventListener('click', closeMobile))

  let lastScroll = 0
  window.addEventListener('scroll', () => {
    const header = document.getElementById('site-header')
    const y = window.scrollY
    if (y > 20) header?.classList.add('scrolled')
    else header?.classList.remove('scrolled')
    lastScroll = y
  }, { passive: true })

  function updateCartCount() {
    const cart = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    const count = cart.reduce((s, i) => s + i.quantity, 0)
    const el = document.getElementById('cart-count')
    const wrap = document.getElementById('cart-icon-wrap')
    if (!el) return
    if (count > 0) {
      el.textContent = count > 99 ? '99+' : String(count)
      el.classList.remove('hidden')
      wrap?.classList.add('cart-bounce')
      setTimeout(() => wrap?.classList.remove('cart-bounce'), 300)
    } else el.classList.add('hidden')
  }
  updateCartCount()
  window.addEventListener('storage', updateCartCount)
  document.addEventListener('cart-updated', updateCartCount)

  const searchBtn = document.getElementById('search-btn')
  const searchOverlay = document.getElementById('search-overlay')
  const searchInput = document.getElementById('search-input')
  const searchResults = document.getElementById('search-results')
  const searchEmpty = document.getElementById('search-empty')
  const searchNoResults = document.getElementById('search-no-results')
  const searchResultsList = document.getElementById('search-results-list')
  let searchTimeout

  function openSearch() {
    searchOverlay?.classList.remove('hidden')
    setTimeout(() => searchInput?.focus(), 100)
    ;[searchEmpty, searchResults, searchNoResults].forEach(el => {
      if (el === searchEmpty) el?.classList.remove('hidden')
      else el?.classList.add('hidden')
    })
  }
  function closeSearch() { searchOverlay?.classList.add('hidden') }

  searchBtn?.addEventListener('click', openSearch)
  document.getElementById('search-overlay-bg')?.addEventListener('click', closeSearch)

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch()
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      searchOverlay?.classList.contains('hidden') ? openSearch() : closeSearch()
    }
  })

  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout)
    const q = searchInput.value.trim()
    if (q.length < 2) {
      searchResults?.classList.add('hidden')
      searchEmpty?.classList.remove('hidden')
      searchNoResults?.classList.add('hidden')
      return
    }
    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch('/api/products?q=' + encodeURIComponent(q) + '&limit=5')
        const data = await res.json()
        searchEmpty?.classList.add('hidden')
        searchNoResults?.classList.add('hidden')
        if (data.length > 0) {
          searchResultsList.innerHTML = data.map((p) => {
            const name = String(p.name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
            return '<a href="/products/' + p.slug + '" class="flex items-center gap-3.5 p-3 rounded-xl hover:bg-surface-50 transition-all group" onclick="closeSearch()">' +
              '<div class="w-14 h-14 bg-surface-100 rounded-xl overflow-hidden shrink-0 ring-1 ring-surface-200/50">' +
              (p.imageUrl ? '<img src="' + p.imageUrl + '" alt="' + name + '" class="w-full h-full object-cover group-hover:scale-110 transition-all duration-500" />' : '<div class="w-full h-full flex items-center justify-center text-surface-300"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>') +
              '</div><div class="flex-1 min-w-0"><p class="text-sm font-semibold text-surface-900 truncate">' + name + '</p><p class="text-sm text-surface-500 mt-0.5">Rs. ' + (p.priceCents / 100).toFixed(2) + '</p></div>' +
              '<svg class="w-4 h-4 text-surface-300 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>'
          }).join('')
          searchResults?.classList.remove('hidden')
        } else {
          searchResults?.classList.add('hidden')
          searchNoResults?.classList.remove('hidden')
        }
      } catch(e) { searchResults?.classList.add('hidden') }
    }, 300)
  })

  const token = localStorage.getItem('vkrama_token')
  const ids = ['account-link', 'login-link', 'mobile-account-link', 'mobile-login-link']
  ids.forEach(id => {
    const el = document.getElementById(id)
    if (!el) return
    if (token && id.includes('login')) el.remove()
    else if (!token && id.includes('account')) el.remove()
  })
</script>
