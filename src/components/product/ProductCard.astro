---
export interface Props {
  slug: string
  name: string
  priceCents: number
  compareAtPriceCents?: number | null
  imageUrl?: string | null
  status?: string
  rating?: number
  reviewCount?: number
  prebookingStatus?: string
}

const { slug, name, priceCents, compareAtPriceCents, imageUrl, status, rating = 0, reviewCount = 0, prebookingStatus } = Astro.props
const hasDiscount = compareAtPriceCents && compareAtPriceCents > priceCents
const discountPercent = hasDiscount ? Math.round((1 - priceCents / compareAtPriceCents!) * 100) : 0
const inStock = status !== 'out_of_stock' && status !== 'discontinued'
const isPrebooking = prebookingStatus === 'prebooking' || prebookingStatus === 'scheduled'
---

<a
  href={`/products/${slug}`}
  class="group relative flex flex-col bg-white rounded-2xl border border-surface-200/60 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-surface-300/80"
>
  <div class="aspect-[4/5] bg-surface-100 overflow-hidden relative">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={name}
        class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-surface-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    <!-- Overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

    <!-- Badges -->
    <div class="absolute top-3 left-3 flex flex-col gap-1.5">
      {hasDiscount && (
        <span class="inline-flex items-center gap-1 rounded-full bg-accent-500 text-white px-2.5 py-0.5 text-2xs font-bold shadow-lg">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {discountPercent}% OFF
        </span>
      )}
      {isPrebooking && (
        <span class="inline-flex items-center gap-1 rounded-full bg-purple-600 text-white px-2.5 py-0.5 text-2xs font-bold shadow-lg">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Pre-order
        </span>
      )}
      {!inStock && !isPrebooking && (
        <span class="badge-red text-2xs shadow-lg">Out of Stock</span>
      )}
    </div>

    <!-- Quick add button -->
    {inStock && (
      <div class="absolute bottom-3 left-3 right-3 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
        <span class="flex items-center justify-center gap-1.5 w-full py-2.5 text-xs font-semibold rounded-xl bg-white/90 backdrop-blur-sm text-surface-900 hover:bg-white hover:shadow-lg transition-all cursor-pointer">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          Quick Add
        </span>
      </div>
    )}
  </div>
  <div class="p-4 flex-1 flex flex-col">
    {reviewCount > 0 && (
      <div class="flex items-center gap-1.5 mb-1.5">
        <div class="flex items-center">
          {[1, 2, 3, 4, 5].map((star) => (
            <svg key={star} class={`w-3 h-3 ${star <= Math.round(rating) ? 'text-amber-400' : 'text-surface-200'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-2xs text-surface-400">({reviewCount})</span>
      </div>
    )}
    <h3 class="font-medium text-surface-900 group-hover:text-brand-600 transition-colors text-sm leading-snug line-clamp-2">
      {name}
    </h3>
    <div class="flex items-baseline gap-2 mt-auto pt-2">
      <p class="text-lg font-bold text-surface-900 tracking-tight">Rs. {(priceCents / 100).toFixed(2)}</p>
      {hasDiscount && (
        <p class="text-sm text-surface-400 line-through">Rs. {(compareAtPriceCents! / 100).toFixed(2)}</p>
      )}
    </div>
  </div>
</a>
