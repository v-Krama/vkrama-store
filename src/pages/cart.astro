---
import Base from '../layouts/Base.astro'
---

<Base title="Shopping Cart">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-8">Shopping Cart</h1>

    <div id="cart-contents">
      <div class="card p-8 text-center text-gray-500">Loading cart...</div>
    </div>

    <div id="checkout-section" class="hidden mt-6">
      <div class="card p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-lg font-semibold text-gray-900">Total</span>
          <span id="cart-total" class="text-2xl font-bold text-gray-900">$0.00</span>
        </div>
        <button id="checkout-btn" class="btn-primary btn-lg w-full">
          Proceed to Checkout
        </button>
      </div>
    </div>

    <div id="empty-cart" class="hidden text-center py-16">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
      </svg>
      <p class="text-gray-500 text-lg mb-4">Your cart is empty</p>
      <a href="/products" class="btn-primary">Continue Shopping</a>
    </div>
  </div>
</Base>

<script>
  interface CartItem {
    id: string
    slug: string
    name: string
    priceCents: number
    quantity: number
    imageUrl: string
    variantId?: string
    variantName?: string
  }

  function renderCart() {
    const cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    const container = document.getElementById('cart-contents')!
    const totalEl = document.getElementById('cart-total')!
    const checkoutSection = document.getElementById('checkout-section')!
    const emptyCart = document.getElementById('empty-cart')!

    if (cart.length === 0) {
      container.innerHTML = ''
      checkoutSection.classList.add('hidden')
      emptyCart.classList.remove('hidden')
      return
    }

    emptyCart.classList.add('hidden')
    checkoutSection.classList.remove('hidden')

    let total = 0
    let html = '<div class="space-y-4">'

    for (const item of cart) {
      const itemTotal = item.priceCents * item.quantity
      total += itemTotal
      html += `
        <div class="card p-4 flex items-center gap-4" data-id="${item.id}">
          <div class="w-20 h-20 bg-gray-100 rounded-lg overflow-hidden shrink-0">
            ${item.imageUrl
              ? `<img src="${item.imageUrl}" alt="${item.name}" class="w-full h-full object-cover" />`
              : `<div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No img</div>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-medium text-gray-900 truncate">${item.name}</h3>
            ${item.variantName ? `<p class="text-sm text-gray-500">${item.variantName}</p>` : ''}
            <p class="text-sm text-gray-500">$${(item.priceCents / 100).toFixed(2)} each</p>
          </div>
          <div class="flex items-center gap-2">
            <button class="btn-secondary btn-sm qty-minus" data-id="${item.id}">-</button>
            <span class="w-8 text-center font-medium">${item.quantity}</span>
            <button class="btn-secondary btn-sm qty-plus" data-id="${item.id}">+</button>
          </div>
          <div class="text-right w-24">
            <p class="font-semibold text-gray-900">$${(itemTotal / 100).toFixed(2)}</p>
            <button class="text-xs text-red-600 hover:text-red-700 remove-item" data-id="${item.id}">Remove</button>
          </div>
        </div>
      `
    }

    html += '</div>'
    container.innerHTML = html
    totalEl.textContent = `$${(total / 100).toFixed(2)}`

    // Event handlers
    container.querySelectorAll('.qty-plus').forEach((btn) => {
      btn.addEventListener('click', () => updateQty(btn.getAttribute('data-id')!, 1))
    })
    container.querySelectorAll('.qty-minus').forEach((btn) => {
      btn.addEventListener('click', () => updateQty(btn.getAttribute('data-id')!, -1))
    })
    container.querySelectorAll('.remove-item').forEach((btn) => {
      btn.addEventListener('click', () => removeItem(btn.getAttribute('data-id')!))
    })
  }

  function updateQty(id: string, delta: number) {
    const cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    const item = cart.find((i) => i.id === id)
    if (!item) return
    item.quantity += delta
    if (item.quantity <= 0) {
      const idx = cart.indexOf(item)
      cart.splice(idx, 1)
    }
    localStorage.setItem('vkrama_cart', JSON.stringify(cart))
    window.dispatchEvent(new Event('cart-updated'))
    renderCart()
  }

  function removeItem(id: string) {
    let cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    cart = cart.filter((i) => i.id !== id)
    localStorage.setItem('vkrama_cart', JSON.stringify(cart))
    window.dispatchEvent(new Event('cart-updated'))
    renderCart()
  }

  renderCart()

  // Checkout
  document.getElementById('checkout-btn')?.addEventListener('click', async () => {
    const cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    if (cart.length === 0) return

    const btn = document.getElementById('checkout-btn') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = 'Redirecting...'

    try {
      const res = await fetch('/api/cart/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: cart.map((i) => ({ slug: i.slug, quantity: i.quantity, variantId: i.variantId, variantName: i.variantName })) }),
      })
      const data = await res.json()
      if (data.orderId) {
        localStorage.removeItem('vkrama_cart')
        window.dispatchEvent(new Event('cart-updated'))
        window.location.href = `/checkout/confirm/${data.orderId}`
      } else {
        alert('Checkout failed. Please try again.')
        btn.disabled = false
        btn.textContent = 'Proceed to Checkout'
      }
    } catch {
      alert('Checkout failed. Please try again.')
      btn.disabled = false
      btn.textContent = 'Proceed to Checkout'
    }
  })
</script>
