---
import Base from '../../../layouts/Base.astro'
import OrderQR from '../../../components/payment/OrderQR.tsx'
import { buildUpiLink } from '../../../lib/payment'

export async function getStaticPaths() {
  return []
}

const orderId = Astro.params.orderId!
let order: Record<string, any> | null = null
let items: any[] = []

try {
  const env = (Astro.locals as any).runtime?.env
  if (env?.DB) {
    const row = await env.DB.prepare('SELECT * FROM orders WHERE id = ?').bind(orderId).first() as any
    if (row) {
      order = row
      const result = await env.DB.prepare('SELECT * FROM order_items WHERE order_id = ?').bind(orderId).all()
      items = result.results as any[]
    }
  }
} catch {}

const upiLink = order ? buildUpiLink({ amountCents: order.total_cents, orderId }) : ''
---

<Base title="Payment">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {order ? (
      <>
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-gray-900">Complete Your Payment</h1>
          <p class="text-gray-500 mt-1">Order #{order.id}</p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="card p-6">
            <h2 class="font-semibold text-gray-900 mb-4">Scan & Pay</h2>
            <OrderQR
              client:load
              upiLink={upiLink}
              orderId={order.id}
              totalCents={order.total_cents}
            />
          </div>

          <div class="space-y-4">
            <div class="card p-6">
              <h2 class="font-semibold text-gray-900 mb-3">Order Summary</h2>
              <div class="space-y-3">
                {items.map((item: any) => (
                  <div class="flex justify-between text-sm">
                    <span class="text-gray-600">
                      {item.name} × {item.quantity}
                    </span>
                    <span class="font-medium">₹{((item.price_cents * item.quantity) / 100).toFixed(2)}</span>
                  </div>
                ))}
              </div>
              <div class="border-t border-gray-200 mt-4 pt-4 flex justify-between font-bold text-lg">
                <span>Total</span>
                <span>₹{(order.total_cents / 100).toFixed(2)}</span>
              </div>
            </div>

            <div class="card p-6 bg-amber-50 border-amber-200">
              <h3 class="font-semibold text-amber-800 mb-2">Instructions</h3>
              <ol class="text-sm text-amber-700 space-y-2 list-decimal list-inside">
                <li>Open any UPI app on your phone</li>
                <li>Scan the QR code</li>
                <li>Complete the payment</li>
                <li>Your order will be processed once payment is confirmed by our team</li>
              </ol>
            </div>
          </div>
        </div>

        <div class="text-center mt-8">
          <a href="/account/orders" class="btn-secondary">View My Orders</a>
        </div>
      </>
    ) : (
      <div class="card p-8 text-center">
        <h1 class="text-xl font-bold text-gray-900 mb-2">Order Not Found</h1>
        <p class="text-gray-500 mb-4">We couldn't find this order. It may not exist or has been removed.</p>
        <a href="/cart" class="btn-primary">Back to Cart</a>
      </div>
    )}
  </div>
</Base>
