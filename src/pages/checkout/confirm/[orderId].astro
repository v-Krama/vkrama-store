---
import Base from '../../../layouts/Base.astro'

export async function getStaticPaths() {
  return []
}

const orderId = Astro.params.orderId!
let order: Record<string, any> | null = null
let items: any[] = []

try {
  const env = (Astro.locals as any).runtime?.env
  if (env?.DB) {
    const row = await env.DB.prepare('SELECT * FROM orders WHERE id = ?').bind(orderId).first() as any
    if (row) {
      order = row
      const result = await env.DB.prepare('SELECT * FROM order_items WHERE order_id = ?').bind(orderId).all()
      items = result.results as any[]
    }
  }
} catch {}
---

<Base title="Order Confirmed">
  <div class="container-page py-8">
    {order ? (
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8 animate-slide-up">
          <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-surface-900">Order Confirmed!</h1>
          <p class="text-surface-500 mt-2">Thank you for your purchase</p>
          <p class="font-mono text-sm text-surface-400 mt-1">Order #{order.id}</p>
        </div>

        <div class="card p-6 mb-6">
          <h2 class="font-semibold text-surface-900 mb-4">Order Details</h2>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-surface-500">Email</span>
              <span>{order.email}</span>
            </div>
            {order.phone && (
              <div class="flex justify-between">
                <span class="text-surface-500">Phone</span>
                <span>{order.phone}</span>
              </div>
            )}
            <div class="flex justify-between">
              <span class="text-surface-500">Status</span>
              <span class="badge-green">Paid</span>
            </div>
            <div class="flex justify-between">
              <span class="text-surface-500">Date</span>
              <span>{new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
            </div>
          </div>
        </div>

        {order.shipping_name && (
          <div class="card p-6 mb-6">
            <h2 class="font-semibold text-surface-900 mb-4">Shipping Address</h2>
            <div class="text-sm text-surface-600 space-y-0.5">
              <p>{order.shipping_name}</p>
              {order.shipping_phone && <p>{order.shipping_phone}</p>}
              <p>{order.shipping_line1}</p>
              {order.shipping_line2 && <p>{order.shipping_line2}</p>}
              <p>{order.shipping_city}, {order.shipping_state} {order.shipping_postal_code}</p>
            </div>
          </div>
        )}

        <div class="card p-6 mb-8">
          <h2 class="font-semibold text-surface-900 mb-4">Items</h2>
          <div class="divide-y divide-surface-100">
            {items.map((item: any) => (
              <div class="flex items-center justify-between py-3 first:pt-0 last:pb-0">
                <div class="flex items-center gap-3">
                  {item.image_url ? (
                    <img src={item.image_url} alt={item.name} class="w-12 h-12 rounded-lg object-cover bg-surface-100" />
                  ) : (
                    <div class="w-12 h-12 rounded-lg bg-surface-100" />
                  )}
                  <div>
                    <p class="text-sm font-medium text-surface-900">{item.name}</p>
                    {item.variant_name && <p class="text-xs text-surface-500">{item.variant_name}</p>}
                    <p class="text-xs text-surface-400">Qty: {item.quantity}</p>
                  </div>
                </div>
                <p class="text-sm font-semibold">${((item.price_cents * item.quantity) / 100).toFixed(2)}</p>
              </div>
            ))}
          </div>
          <div class="divider my-4" />
          <div class="space-y-1.5 text-sm">
            <div class="flex justify-between text-surface-600">
              <span>Subtotal</span>
              <span>${(order.subtotal_cents / 100).toFixed(2)}</span>
            </div>
            <div class="flex justify-between text-surface-600">
              <span>Shipping</span>
              <span>{order.shipping_cents === 0 ? 'Free' : `$${(order.shipping_cents / 100).toFixed(2)}`}</span>
            </div>
            <div class="flex justify-between text-surface-600">
              <span>Tax</span>
              <span>${(order.tax_cents / 100).toFixed(2)}</span>
            </div>
            <div class="divider" />
            <div class="flex justify-between font-bold text-surface-900 text-base pt-2">
              <span>Total</span>
              <span>${(order.total_cents / 100).toFixed(2)}</span>
            </div>
          </div>
        </div>

        <div class="text-center">
          <p class="text-sm text-surface-500 mb-4">A confirmation email has been sent to your email address.</p>
          <a href="/account/orders" class="btn-primary">View My Orders</a>
        </div>
      </div>
    ) : (
      <div class="max-w-md mx-auto text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-surface-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-xl font-bold text-surface-900 mb-2">Order Not Found</h2>
        <p class="text-surface-500 mb-6">We couldn't find this order. It may have been placed from a different account.</p>
        <a href="/account/orders" class="btn-primary">My Orders</a>
      </div>
    )}
  </div>
</Base>
