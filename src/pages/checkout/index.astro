---
import Base from '../../layouts/Base.astro'
---
<Base title="Checkout">
  <div class="relative min-h-screen bg-surface-50/50">
    <div class="container-page py-6 lg:py-10">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex items-center gap-3 mb-8">
          <a href="/cart" class="btn-ghost btn-icon -ml-2" aria-label="Back">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <div>
            <h1 class="text-xl lg:text-2xl font-bold text-surface-900">Checkout</h1>
            <p class="text-sm text-surface-500">Complete your order</p>
          </div>
        </div>

        <div id="checkout-contents">
          <div class="rounded-2xl bg-white border border-surface-200 p-8 sm:p-12 text-center text-surface-500">
            <div class="w-8 h-8 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
            <p class="text-sm">Loading checkout...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  const TOKEN = localStorage.getItem('vkrama_token')

  if (!TOKEN) {
    window.location.href = '/auth/login?redirect=/checkout'
  }

  let CURRENT_USER: { id: string; email: string; name?: string } | null = null

  ;(async function init() {
    if (!TOKEN) return
    try {
      const res = await fetch('/api/auth/me', { headers: { 'Authorization': `Bearer ${TOKEN}` } })
      if (!res.ok) throw new Error('Unauthorized')
      const data = await res.json()
      if (!data.user) throw new Error('No user')
      CURRENT_USER = data.user
      renderCheckout()
      togglePaymentDetails()
    } catch {
      localStorage.removeItem('vkrama_token')
      window.location.href = '/auth/login?redirect=/checkout'
    }
  })()

  function renderCheckout() {
    const cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    const container = document.getElementById('checkout-contents')!

    if (cart.length === 0) {
      container.innerHTML = `
        <div class="rounded-2xl bg-white border border-surface-200 p-12 text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-surface-100 flex items-center justify-center">
            <svg class="w-8 h-8 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          </div>
          <p class="text-surface-900 font-semibold mb-1">Your cart is empty</p>
          <p class="text-surface-500 text-sm mb-6">Add some products before checking out</p>
          <a href="/products" class="btn-primary">Browse Products</a>
        </div>
      `
      return
    }

    const total = cart.reduce((sum, item) => sum + (item.price || item.priceCents || 0) * item.quantity, 0)
    const subtotal = total
    const shippingCents = subtotal >= 500000 ? 0 : 50000
    const taxCents = Math.round(subtotal * 0.13)
    const grandTotal = subtotal + shippingCents + taxCents

    let itemsHtml = ''
    for (const item of cart) {
      itemsHtml += `
        <div class="flex items-center gap-3 py-3 border-b border-surface-100 last:border-0">
          <div class="w-14 h-14 bg-surface-100 rounded-lg overflow-hidden shrink-0 ring-1 ring-surface-200/50">
            ${(item.imageUrl || item.image) ? `<img src="${item.imageUrl || item.image}" alt="${item.name}" class="w-full h-full object-cover" />` : '<div class="w-full h-full flex items-center justify-center text-surface-300"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>'}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-surface-900 truncate">${item.name}</p>
            <p class="text-xs text-surface-500">Qty: ${item.quantity} &times; ${fp(item.price || item.priceCents)}</p>
          </div>
          <p class="text-sm font-semibold text-surface-900">${fp((item.price || item.priceCents) * item.quantity)}</p>
        </div>
      `
    }

    container.innerHTML = `
      <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 items-start">
        <div class="lg:col-span-2 space-y-6">
          <!-- Logged in as -->
          <div class="rounded-2xl bg-white border border-surface-200 p-5">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-brand-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-surface-900">${CURRENT_USER!.name || 'Customer'}</p>
                <p class="text-xs text-surface-500">${CURRENT_USER!.email}</p>
              </div>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="rounded-2xl bg-white border border-surface-200 p-5 sm:p-6">
            <h2 class="text-base font-semibold text-surface-900 mb-4">Contact Information</h2>
            <div class="space-y-4">
              <div>
                <label class="label" for="email">Email</label>
                <input type="email" id="email" class="input bg-surface-50" value="${CURRENT_USER!.email}" readonly />
              </div>
              <div>
                <label class="label" for="phone">Phone (for delivery)</label>
                <input type="tel" id="phone" class="input" placeholder="98XXXXXXXX" />
              </div>
            </div>
          </div>

          <!-- Shipping Address -->
          <div class="rounded-2xl bg-white border border-surface-200 p-5 sm:p-6">
            <h2 class="text-base font-semibold text-surface-900 mb-4">Shipping Address</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="col-span-2 sm:col-span-1">
                <label class="label" for="ship-name">Full Name</label>
                <input type="text" id="ship-name" class="input" value="${CURRENT_USER!.name || ''}" placeholder="Full Name" />
              </div>
              <div class="col-span-2 sm:col-span-1">
                <label class="label" for="ship-phone">Phone</label>
                <input type="tel" id="ship-phone" class="input" placeholder="98XXXXXXXX" />
              </div>
              <div class="col-span-2">
                <label class="label" for="ship-line1">Address Line 1</label>
                <input type="text" id="ship-line1" class="input" placeholder="Street, area, landmark" />
              </div>
              <div class="col-span-2">
                <label class="label" for="ship-line2">Address Line 2 (optional)</label>
                <input type="text" id="ship-line2" class="input" placeholder="Apartment, floor, building" />
              </div>
              <div>
                <label class="label" for="ship-city">City</label>
                <input type="text" id="ship-city" class="input" placeholder="Kathmandu" />
              </div>
              <div>
                <label class="label" for="ship-state">State/Province</label>
                <input type="text" id="ship-state" class="input" placeholder="Bagmati" />
              </div>
              <div>
                <label class="label" for="ship-zip">Postal Code</label>
                <input type="text" id="ship-zip" class="input" placeholder="44600" />
              </div>
            </div>
          </div>

          <!-- Payment Method -->
          <div class="rounded-2xl bg-white border border-surface-200 p-5 sm:p-6">
            <h2 class="text-base font-semibold text-surface-900 mb-4">Payment Method</h2>
            <div class="space-y-3">
              <label class="flex items-center gap-3 p-3.5 rounded-xl border border-surface-200 cursor-pointer hover:border-brand-300 has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50/50 transition-all">
                <input type="radio" name="payment" value="qr" checked class="accent-brand-600 w-4 h-4" onchange="togglePaymentDetails()" />
                <div class="w-10 h-10 rounded-lg bg-surface-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-surface-900">Scan &amp; Pay (QR)</p>
                  <p class="text-xs text-surface-500">Pay using your payment app</p>
                </div>
              </label>
              <label class="flex items-center gap-3 p-3.5 rounded-xl border border-surface-200 cursor-pointer hover:border-brand-300 has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50/50 transition-all">
                <input type="radio" name="payment" value="cod" class="accent-brand-600 w-4 h-4" onchange="togglePaymentDetails()" />
                <div class="w-10 h-10 rounded-lg bg-surface-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-surface-900">Cash on Delivery</p>
                  <p class="text-xs text-surface-500">Pay when you receive your items</p>
                </div>
              </label>
            </div>
            <div id="qr-payment-details" class="mt-5 pt-5 border-t border-surface-200">
              <div class="flex flex-col sm:flex-row items-start gap-5">
                <div class="w-48 h-48 rounded-xl bg-white border border-surface-200 overflow-hidden shrink-0 flex items-center justify-center p-2">
                  <img src="/payment-qr.jpeg" alt="Payment QR" class="w-full h-full object-contain" />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-surface-900 text-sm mb-3">Bank Transfer Details</h3>
                  <div class="bg-surface-50 rounded-xl p-4 space-y-2 text-sm">
                    <div class="flex justify-between gap-4">
                      <span class="text-surface-500 shrink-0">Account Name</span>
                      <span class="font-medium text-surface-900 text-right">VKRAMA GROUP PVT.LTD.</span>
                    </div>
                    <div class="flex justify-between gap-4">
                      <span class="text-surface-500 shrink-0">Account Type</span>
                      <span class="font-medium text-surface-900">CURRENT ACCOUNT GENERAL</span>
                    </div>
                    <div class="flex justify-between gap-4">
                      <span class="text-surface-500 shrink-0">Account Number</span>
                      <span class="font-mono font-bold text-surface-900 text-base tracking-wider">19101017501227</span>
                    </div>
                    <div class="flex justify-between gap-4">
                      <span class="text-surface-500 shrink-0">Bank</span>
                      <span class="font-medium text-surface-900">Nabil Bank Limited</span>
                    </div>
                  </div>
                  <div class="mt-3 flex items-center gap-2 text-xs text-amber-700 bg-amber-50 rounded-lg px-3 py-2">
                    <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    After payment, place your order and we'll confirm it manually.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="lg:col-span-1">
          <div class="rounded-2xl bg-white border border-surface-200 p-5 sm:p-6 lg:sticky lg:top-24">
            <h2 class="text-base font-semibold text-surface-900 mb-4">Order Summary</h2>
            <div class="divide-y divide-surface-100">${itemsHtml}</div>
            <div class="mt-4 pt-4 border-t border-surface-200 space-y-2 text-sm">
              <div class="flex justify-between text-surface-600">
                <span>Subtotal</span>
                <span>${fp(subtotal)}</span>
              </div>
              <div class="flex justify-between text-surface-600">
                <span>Shipping</span>
                <span>${shippingCents === 0 ? '<span class="text-emerald-600 font-medium">Free</span>' : fp(shippingCents)}</span>
              </div>
              <div class="flex justify-between text-surface-600">
                <span>Tax (13%)</span>
                <span>${fp(taxCents)}</span>
              </div>
              <div class="flex justify-between font-bold text-surface-900 text-base pt-2 border-t border-surface-200">
                <span>Total</span>
                <span>${fp(grandTotal)}</span>
              </div>
            </div>
            <button id="place-order-btn" class="btn-primary w-full btn-lg mt-5 text-base">
              Place Order
            </button>
            <p id="checkout-error" class="text-sm text-red-600 mt-3 hidden"></p>
            <p class="text-xs text-surface-400 text-center mt-3 leading-relaxed">
              By placing this order, you agree to our <a href="/terms" class="underline hover:text-surface-600">terms and conditions</a>.
            </p>
            <div class="mt-4 pt-4 border-t border-surface-200 flex items-center justify-center gap-3 text-surface-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              <span class="text-2xs">Secure checkout</span>
            </div>
          </div>
        </div>
      </div>
    `
    document.getElementById('place-order-btn')?.addEventListener('click', placeOrder)
  }

  function togglePaymentDetails() {
    const el = document.getElementById('qr-payment-details')
    const qr = document.querySelector('input[name="payment"][value="qr"]') as HTMLInputElement
    if (el) el.style.display = qr?.checked ? '' : 'none'
  }

  async function placeOrder() {
    const cart: CartItem[] = JSON.parse(localStorage.getItem('vkrama_cart') || '[]')
    if (cart.length === 0) return

    const btn = document.getElementById('place-order-btn') as HTMLButtonElement
    const errorEl = document.getElementById('checkout-error')!

    const getVal = (id: string) => (document.getElementById(id) as HTMLInputElement).value
    const paymentMethodEl = document.querySelector('input[name="payment"]:checked') as HTMLInputElement
    const paymentMethod = paymentMethodEl?.value || 'qr'

    btn.disabled = true
    btn.innerHTML = '<span class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span> Processing...'
    errorEl.classList.add('hidden')

    const shippingInfo = {
      name: getVal('ship-name') || undefined,
      phone: getVal('ship-phone') || undefined,
      line1: getVal('ship-line1') || undefined,
      line2: getVal('ship-line2') || undefined,
      city: getVal('ship-city') || undefined,
      state: getVal('ship-state') || undefined,
      postalCode: getVal('ship-zip') || undefined,
    }

    try {
      const res = await fetch('/api/cart/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${TOKEN}` },
        body: JSON.stringify({
          paymentMethod,
          phone: getVal('phone') || undefined,
          shippingInfo: shippingInfo.name ? shippingInfo : undefined,
          items: cart.map((i) => ({
            slug: i.slug,
            quantity: i.quantity,
            variantId: i.variantId,
            variantName: i.variantName,
          })),
        }),
        signal: AbortSignal.timeout(30000),
      })
      const data = await res.json()

      if (data.orderId) {
        localStorage.removeItem('vkrama_cart')
        window.dispatchEvent(new Event('cart-updated'))
        window.location.href = `/checkout/confirm/${data.orderId}`
      } else {
        errorEl.textContent = data.error || 'Checkout failed. Please try again.'
        errorEl.classList.remove('hidden')
        btn.disabled = false
        btn.innerHTML = 'Place Order'
      }
    } catch {
      errorEl.textContent = 'Network error. Please try again.'
      errorEl.classList.remove('hidden')
      btn.disabled = false
      btn.innerHTML = 'Place Order'
    }
  }
</script>
