---
import Admin from '../../../layouts/Admin.astro'
---

<Admin title="Order Detail">
  <div id="order-content">
    <div class="card p-8 text-center text-gray-500">Loading...</div>
  </div>
</Admin>

<script>
  const orderId = window.location.pathname.split('/').pop()

  async function loadOrder() {
    const token = localStorage.getItem('vkrama_admin_token')
    try {
      const res = await fetch(`/api/admin/orders/${orderId}`, {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) { window.location.href = '/admin/login'; return }
      const o = await res.json()
      const container = document.getElementById('order-content')!

      const statusClass = (s: string) => {
        const map: Record<string, string> = { delivered: 'badge-green', cancelled: 'badge-red', paid: 'badge-blue', processing: 'badge-blue', shipped: 'badge-blue', pending: 'badge-yellow', awaiting_payment: 'badge-yellow' }
        return map[s] || 'badge-gray'
      }

      const statuses = ['pending', 'awaiting_payment', 'paid', 'processing', 'shipped', 'delivered', 'cancelled']
      const statusOpts = statuses.map((s) =>
        `<option value="${s}" ${s === o.status ? 'selected' : ''}>${s}</option>`
      ).join('')

      let itemsHtml = ''
      for (const item of o.items || []) {
        itemsHtml += `<div class="flex items-center justify-between py-2 border-b border-gray-100"><span>${item.name}${item.variantName ? ` (${item.variantName})` : ''} × ${item.quantity}</span><span class="font-medium">$${((item.priceCents * item.quantity) / 100).toFixed(2)}</span></div>`
      }

      container.innerHTML = `
        <div class="grid grid-cols-3 gap-6">
          <div class="col-span-2 space-y-6">
            <div class="card p-6">
              <h3 class="font-semibold text-gray-900 mb-4">Order #${o.id}</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Date</span><span>${new Date(o.createdAt).toLocaleString()}</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Email</span><span>${o.email}</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Status</span><span class="${statusClass(o.status)}">${o.status}</span></div>
              </div>
              <div class="mt-4 pt-4 border-t border-gray-200">
                <label class="label" for="status-select">Update Status</label>
                <div class="flex gap-2">
                  <select id="status-select" class="input flex-1">${statusOpts}</select>
                  <button id="update-status" class="btn-primary btn-sm">Update</button>
                </div>
              </div>
            </div>
            <div class="card p-6">
              <h3 class="font-semibold text-gray-900 mb-4">Items</h3>
              ${itemsHtml || '<p class="text-gray-500">No items</p>'}
              <div class="mt-4 pt-4 border-t border-gray-200 space-y-1 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Subtotal</span><span>$${(o.subtotalCents / 100).toFixed(2)}</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Shipping</span><span>${o.shippingCents === 0 ? 'Free' : `$${(o.shippingCents / 100).toFixed(2)}`}</span></div>
                <div class="flex justify-between font-bold text-base pt-2 border-t border-gray-200 mt-2"><span>Total</span><span>$${(o.totalCents / 100).toFixed(2)}</span></div>
              </div>
            </div>
          </div>
          <div class="space-y-6">
            ${o.shippingAddress ? `
            <div class="card p-6">
              <h3 class="font-semibold text-gray-900 mb-3">Shipping</h3>
              <pre class="text-sm text-gray-600 whitespace-pre-wrap font-sans">${JSON.parse(o.shippingAddress).name || o.email}
${JSON.parse(o.shippingAddress).line1 || ''}
${JSON.parse(o.shippingAddress).city || ''} ${JSON.parse(o.shippingAddress).state || ''} ${JSON.parse(o.shippingAddress).postal_code || ''}</pre>
            </div>` : ''}

          </div>
        </div>
      `

      document.getElementById('update-status')?.addEventListener('click', async () => {
        const status = (document.getElementById('status-select') as HTMLSelectElement).value
        const res = await fetch(`/api/admin/orders/${orderId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ status }),
        })
        if (res.ok) location.reload()
        else alert('Update failed')
      })
    } catch {
      document.getElementById('order-content')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load order.</div>'
    }
  }
  loadOrder()
</script>
