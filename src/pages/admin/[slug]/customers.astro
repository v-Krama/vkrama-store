---
import Admin from '../../../layouts/Admin.astro'
import { getAdminSlug } from '../../../lib/constants'

const { slug } = Astro.params
if (!slug || slug !== getAdminSlug()) return Astro.redirect('/404')
---

<Admin title="Customers">
  <div id="customers-table">
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="bg-surface-50 border-b border-surface-200">
          <th class="px-4 py-3 text-left font-medium text-surface-600">Name</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Email</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Orders</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Joined</th>
        </tr></thead>
        <tbody class="divide-y divide-surface-200" id="customers-body">
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-40 h-4"></div></td></tr>
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-32 h-4"></div></td></tr>
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-48 h-4"></div></td></tr>
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-36 h-4"></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Admin>

<script define:vars={{ slug }}>
  async function loadCustomers() {
    const token = localStorage.getItem('vkrama_admin_token')
    if (!token) { window.location.href = '/admin/' + slug + '/login'; return }
    try {
      const res = await fetch('/api/admin/customers', { headers: { Authorization: `Bearer ${token}` }, signal: AbortSignal.timeout(15000) })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const customers = await res.json()
      const container = document.getElementById('customers-table')!
      if (!Array.isArray(customers) || customers.length === 0) {
        container.innerHTML = '<div class="card p-8 text-center text-surface-500">No customers yet.</div>'
        return
      }
      const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      let html = '<div class="card overflow-hidden"><table class="w-full text-sm"><thead><tr class="bg-surface-50 border-b border-surface-200"><th class="px-4 py-3 text-left font-medium text-surface-600">Name</th><th class="px-4 py-3 text-left font-medium text-surface-600">Email</th><th class="px-4 py-3 text-left font-medium text-surface-600">Orders</th><th class="px-4 py-3 text-left font-medium text-surface-600">Joined</th></tr></thead><tbody class="divide-y divide-surface-200">'
      for (const c of customers) {
        html += `<tr>
          <td class="px-4 py-3 font-medium text-surface-900">${e(String(c.name || '—'))}</td>
          <td class="px-4 py-3 text-surface-700">${e(String(c.email))}</td>
          <td class="px-4 py-3">${c.orderCount || 0}</td>
          <td class="px-4 py-3 text-sm text-surface-500">${c.createdAt ? new Date(c.createdAt).toLocaleDateString() : '—'}</td>
        </tr>`
      }
      html += '</tbody></table></div>'
      container.innerHTML = html
    } catch {
      document.getElementById('customers-table')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load.</div>'
    }
  }
  loadCustomers()
</script>
