---
import Admin from '../../../layouts/Admin.astro'
import { getAdminSlug } from '../../../lib/constants'

const { slug } = Astro.params
if (!slug || slug !== getAdminSlug()) return Astro.redirect('/404')
---

<Admin title="Categories">
  <div class="mb-6 flex items-center justify-between">
    <p id="category-count" class="text-sm text-surface-500">Loading...</p>
    <button id="add-cat-btn" class="btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
      Add Category
    </button>
  </div>
  <div id="categories-list">
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="bg-surface-50 border-b border-surface-200">
          <th class="px-4 py-3 text-left font-medium text-surface-600">Name</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Slug</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Products</th>
          <th class="px-4 py-3 text-left font-medium text-surface-600">Actions</th>
        </tr></thead>
        <tbody class="divide-y divide-surface-200" id="categories-body">
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-32 h-4"></div></td></tr>
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-24 h-4"></div></td></tr>
          <tr><td class="px-4 py-3" colspan="4"><div class="skeleton-cell w-40 h-4"></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="cat-modal" class="modal hidden">
    <div class="overlay" id="cat-overlay"></div>
    <div class="modal-content p-6">
      <h3 class="text-lg font-semibold text-surface-900 mb-4">Add Category</h3>
      <div class="space-y-4">
        <div>
          <label class="label" for="cat-name">Name</label>
          <input type="text" id="cat-name" class="input" placeholder="Category name" />
        </div>
        <div class="flex gap-3 justify-end">
          <button id="cat-cancel" class="btn-secondary">Cancel</button>
          <button id="cat-save" class="btn-primary">Save</button>
        </div>
      </div>
    </div>
  </div>
</Admin>

<script define:vars={{ slug }}>
  const token = () => localStorage.getItem('vkrama_admin_token')

  async function loadCategories() {
    try {
      const res = await fetch('/api/admin/categories?all=1', {
        headers: { Authorization: `Bearer ${token()}` },
        signal: AbortSignal.timeout(15000),
      })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const cats = await res.json()
      document.getElementById('category-count')!.textContent = `${cats.length} categories`
      const container = document.getElementById('categories-list')!
      if (!Array.isArray(cats) || cats.length === 0) {
        container.innerHTML = '<div class="card p-8 text-center text-surface-500">No categories yet.</div>'
        return
      }
      const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      let html = '<div class="card overflow-hidden"><table class="w-full text-sm"><thead><tr class="bg-surface-50 border-b border-surface-200"><th class="px-4 py-3 text-left font-medium text-surface-600">Name</th><th class="px-4 py-3 text-left font-medium text-surface-600">Slug</th><th class="px-4 py-3 text-left font-medium text-surface-600">Products</th><th class="px-4 py-3 text-left font-medium text-surface-600">Actions</th></tr></thead><tbody class="divide-y divide-surface-200">'
      for (const cat of cats) {
        const safeId = String(cat.id).replace(/[^a-zA-Z0-9_-]/g, '')
        html += `<tr>
          <td class="px-4 py-3 font-medium text-surface-900">${e(String(cat.name))}</td>
          <td class="px-4 py-3 text-surface-500 font-mono text-xs">${e(String(cat.slug))}</td>
          <td class="px-4 py-3">${cat.productCount || 0}</td>
          <td class="px-4 py-3">
            <button class="text-red-600 hover:text-red-700 text-sm font-medium delete-cat" data-id="${safeId}">Delete</button>
          </td>
        </tr>`
      }
      html += '</tbody></table></div>'
      container.innerHTML = html

      container.querySelectorAll('.delete-cat').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('Delete this category?')) return
          const id = (btn as HTMLElement).dataset.id
          const res = await fetch(`/api/admin/categories/${id}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token()}` } })
          if (res.ok) {
            (window as any).showToast?.('Category deleted', 'success')
            loadCategories()
          } else {
            (window as any).showToast?.('Delete failed', 'error')
          }
        })
      })
    } catch {
      document.getElementById('category-count')!.textContent = 'Failed to load'
      document.getElementById('categories-list')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load.</div>'
    }
  }

  document.getElementById('add-cat-btn')?.addEventListener('click', () => {
    document.getElementById('cat-modal')!.classList.remove('hidden');
    (document.getElementById('cat-name') as HTMLInputElement).value = '';
    (document.getElementById('cat-name') as HTMLInputElement).focus()
  })

  document.getElementById('cat-cancel')?.addEventListener('click', () => {
    document.getElementById('cat-modal')!.classList.add('hidden')
  })

  document.getElementById('cat-overlay')?.addEventListener('click', () => {
    document.getElementById('cat-modal')!.classList.add('hidden')
  })

  document.getElementById('cat-save')?.addEventListener('click', async () => {
    const name = (document.getElementById('cat-name') as HTMLInputElement).value.trim()
    if (!name) return
    const btn = document.getElementById('cat-save') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = 'Saving...'
    try {
      const res = await fetch('/api/admin/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token()}` },
        body: JSON.stringify({ name }),
      })
      if (res.ok) {
        document.getElementById('cat-modal')!.classList.add('hidden');
        (window as any).showToast?.('Category created', 'success')
        loadCategories()
      } else {
        const data = await res.json();
        (window as any).showToast?.(data.error || 'Failed', 'error')
      }
    } catch {
      (window as any).showToast?.('Network error', 'error')
    } finally {
      btn.disabled = false
      btn.textContent = 'Save'
    }
  })

  document.getElementById('cat-name')?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') (document.getElementById('cat-save') as HTMLButtonElement)?.click()
    if (e.key === 'Escape') document.getElementById('cat-modal')!.classList.add('hidden')
  })

  loadCategories()
</script>
