---
import Admin from '../../../layouts/Admin.astro'

const { slug } = Astro.params
---

<Admin title="Dashboard">
  <div id="stats-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="card p-5">
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">Revenue</p>
      <p id="stat-revenue" class="text-2xl font-bold text-surface-900 mt-1">Rs. 0</p>
      <p id="stat-revenue-change" class="text-xs text-surface-400 mt-0.5"></p>
    </div>
    <div class="card p-5">
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">Orders</p>
      <p id="stat-orders" class="text-2xl font-bold text-surface-900 mt-1">0</p>
      <p id="stat-orders-pending" class="text-xs text-amber-600 mt-0.5"></p>
    </div>
    <div class="card p-5">
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">Products</p>
      <p id="stat-products" class="text-2xl font-bold text-surface-900 mt-1">0</p>
      <p id="stat-products-active" class="text-xs text-emerald-600 mt-0.5"></p>
    </div>
    <div class="card p-5">
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">Customers</p>
      <p id="stat-customers" class="text-2xl font-bold text-surface-900 mt-1">0</p>
      <p id="stat-customers-new" class="text-xs text-brand-600 mt-0.5"></p>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 card">
      <div class="px-6 py-4 border-b border-surface-200 flex items-center justify-between">
        <h2 class="font-semibold text-surface-900">Recent Orders</h2>
        <a href={"/admin/" + slug + "/orders"} class="text-sm text-brand-600 hover:underline">View All</a>
      </div>
      <div id="recent-orders" class="p-6 text-center text-surface-500 text-sm">Loading...</div>
    </div>
    <div class="card">
      <div class="px-6 py-4 border-b border-surface-200">
        <h2 class="font-semibold text-surface-900">Quick Actions</h2>
      </div>
      <div class="p-4 space-y-2">
        <a href={"/admin/" + slug + "/products/new"} class="flex items-center gap-3 p-3 rounded-lg hover:bg-brand-50 transition-colors">
          <div class="w-9 h-9 rounded-lg bg-brand-50 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-700">Add Product</span>
        </a>
        <a href={"/admin/" + slug + "/categories"} class="flex items-center gap-3 p-3 rounded-lg hover:bg-brand-50 transition-colors">
          <div class="w-9 h-9 rounded-lg bg-purple-50 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-700">Manage Categories</span>
        </a>
        <a href={"/admin/" + slug + "/orders"} class="flex items-center gap-3 p-3 rounded-lg hover:bg-brand-50 transition-colors">
          <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-700">View Orders</span>
        </a>
        <a href="/" class="flex items-center gap-3 p-3 rounded-lg hover:bg-brand-50 transition-colors">
          <div class="w-9 h-9 rounded-lg bg-surface-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-700">View Store</span>
        </a>
      </div>
    </div>
  </div>
</Admin>

<script define:vars={{ slug }}>
  const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  async function loadStats() {
    const token = localStorage.getItem('vkrama_admin_token')
    if (!token) { window.location.href = '/admin/' + slug + '/login'; return }

    try {
      const res = await fetch('/api/admin/stats', {
        headers: { Authorization: `Bearer ${token}` },
        signal: AbortSignal.timeout(15000),
      })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const stats = await res.json()

      document.getElementById('stat-revenue')!.textContent = fp(stats.totalRevenueCents)
      document.getElementById('stat-orders')!.textContent = stats.totalOrders
      document.getElementById('stat-products')!.textContent = stats.totalProducts
      document.getElementById('stat-customers')!.textContent = stats.totalCustomers

      if (stats.pendingOrders > 0) {
        document.getElementById('stat-orders-pending')!.textContent = `${stats.pendingOrders} pending`
      }
      if (stats.activeProducts > 0) {
        document.getElementById('stat-products-active')!.textContent = `${stats.activeProducts} active`
      }

      const ordersEl = document.getElementById('recent-orders')!
      if (stats.recentOrders?.length > 0) {
        let html = '<div class="divide-y divide-surface-100">'
        for (const o of stats.recentOrders) {
          const statusClass = o.status === 'delivered' ? 'badge-green' :
                             o.status === 'cancelled' ? 'badge-red' :
                             o.status === 'paid' ? 'badge-blue' :
                             o.status === 'shipped' ? 'badge-purple' : 'badge-yellow'
          const safeId = String(o.id).replace(/[^a-zA-Z0-9_-]/g, '')
          html += `
            <a href="/admin/${slug}/orders/${safeId}" class="flex items-center justify-between px-6 py-3.5 hover:bg-brand-50 transition-colors">
              <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-lg bg-surface-100 flex items-center justify-center">
                  <span class="font-mono text-2xs text-surface-500">#${String(o.id).slice(-6)}</span>
                </div>
                <div>
                  <p class="text-sm font-medium text-surface-900">${e(String(o.email))}</p>
                  <p class="text-xs text-surface-400">${new Date(o.createdAt).toLocaleDateString()}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold text-surface-900">${fp(o.totalCents)}</p>
                <span class="${statusClass}">${e(String(o.status))}</span>
              </div>
            </a>
          `
        }
        html += '</div>'
        ordersEl.innerHTML = html
      } else {
        ordersEl.innerHTML = '<p class="text-surface-400 py-4">No recent orders.</p>'
      }
    } catch {
      document.getElementById('stat-revenue')!.textContent = 'Error'
      document.getElementById('stat-orders')!.textContent = '—'
      document.getElementById('stat-products')!.textContent = '—'
      document.getElementById('stat-customers')!.textContent = '—'
      document.getElementById('recent-orders')!.innerHTML = '<p class="text-surface-400 py-4">Failed to load.</p>'
    }
  }
  loadStats()
</script>
