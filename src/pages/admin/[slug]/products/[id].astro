---
import Admin from '../../../../layouts/Admin.astro'
import { getAdminSlug } from '../../../../lib/constants'

const { slug } = Astro.params
if (!slug || slug !== getAdminSlug()) return Astro.redirect('/404')
---

<Admin title="Edit Product">
  <div class="max-w-3xl">
    <div id="form-loading" class="card p-8 text-center text-surface-500">
      <div class="w-6 h-6 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
      Loading product...
    </div>
    <form id="product-form" class="card p-6 space-y-6 hidden">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="label" for="name">Name *</label>
          <input type="text" id="name" class="input" required />
        </div>
        <div class="col-span-2">
          <label class="label" for="description">Description</label>
          <textarea id="description" rows={4} class="input"></textarea>
        </div>
        <div>
          <label class="label" for="price">Price (Rs.) *</label>
          <input type="number" id="price" step="0.01" min="0" class="input" required />
        </div>
        <div>
          <label class="label" for="compare_price">Compare at Price (Rs.)</label>
          <input type="number" id="compare_price" step="0.01" min="0" class="input" />
        </div>
        <div>
          <label class="label" for="stock">Stock</label>
          <input type="number" id="stock" min="0" class="input" value="0" />
        </div>
        <div>
          <label class="label" for="status">Status</label>
          <select id="status" class="select">
            <option value="draft">Draft</option>
            <option value="active">Active</option>
            <option value="archived">Archived</option>
          </select>
        </div>
        <div class="col-span-2">
          <label class="label">Image URL</label>
          <div class="flex gap-2">
            <input type="url" id="image_url" class="input flex-1" />
            <button type="button" id="upload-btn" class="btn-secondary btn-sm">Upload</button>
            <input type="file" id="file-input" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden" />
          </div>
          <div id="image-preview" class="hidden mt-2">
            <img src="" alt="Preview" class="h-32 rounded-lg object-cover" id="preview-img" />
          </div>
        </div>
        <div class="col-span-2">
          <div class="border-t border-surface-200 pt-4">
            <h3 class="font-semibold text-surface-900 mb-3">SEO</h3>
            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <label class="label">SEO Title</label>
                <input type="text" id="seo_title" class="input" />
              </div>
              <div class="col-span-2">
                <label class="label">SEO Description</label>
                <textarea id="seo_description" rows={2} class="input"></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-surface-200 pt-4">
        <h3 class="font-semibold text-surface-900 mb-3">Variants</h3>
        <div class="flex gap-2 mb-3">
          <input type="text" placeholder="Group (e.g. Size)" class="input flex-1 variant-group" />
          <input type="text" placeholder="Value (e.g. Medium)" class="input flex-1 variant-value" />
          <button type="button" class="btn-secondary btn-sm add-option" id="add-option-btn">+ Add</button>
        </div>
        <div id="variant-list" class="space-y-2">
          <p class="text-sm text-surface-400">Add variant options (e.g. Size: Small, Color: Red)</p>
        </div>
        <p class="text-xs text-surface-400 mt-2">Note: Changing variants will regenerate all combinations.</p>
      </div>

      <p id="error-msg" class="text-sm text-red-600 hidden"></p>
      <div class="flex gap-3">
        <button type="submit" class="btn-primary">Update Product</button>
        <button type="button" id="delete-btn" class="btn-danger">Delete</button>
        <a href={"/admin/" + slug + "/products"} class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</Admin>

<script is:inline>
  const _slug = window.location.pathname.split('/')[2]
  const productId = window.location.pathname.split('/').pop()
  const options: Array<{ group: string; value: string }> = []

  function renderVariants() {
    const el = document.getElementById('variant-list')!
    if (options.length === 0) {
      el.innerHTML = '<p class="text-sm text-surface-400">No variants added yet.</p>'
      return
    }
    const groups = [...new Set(options.map((o: any) => o.group))]
    let html = '<div class="space-y-1.5">'
    for (const group of groups) {
      const vals = options.filter((o: any) => o.group === group).map((o: any) => ({ value: o.value, group: o.group }))
      html += `<div class="text-sm bg-surface-50 rounded-lg px-3 py-2 flex items-center justify-between">`
      html += `<span><span class="font-medium">${group}:</span> ${vals.map((v: any) => v.value).join(', ')}</span>`
      html += `<button class="text-red-500 hover:text-red-700 text-xs font-medium remove-group" data-group="${group}">Remove</button>`
      html += `</div>`
    }
    html += '</div>'
    el.innerHTML = html

    el.querySelectorAll('.remove-group').forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = (btn as HTMLElement).dataset.group
        const remaining = options.filter((o: any) => o.group !== group)
        options.length = 0
        options.push(...remaining)
        renderVariants()
      })
    })
  }

  document.getElementById('add-option-btn')?.addEventListener('click', () => {
    const group = document.querySelector('.variant-group') as HTMLInputElement
    const value = document.querySelector('.variant-value') as HTMLInputElement
    if (!group.value || !value.value) return
    options.push({ group: group.value, value: value.value })
    group.value = ''
    value.value = ''
    renderVariants()
  })

  async function loadProduct() {
    const token = localStorage.getItem('vkrama_admin_token')
    try {
      const res = await fetch(`/api/admin/products/${productId}`, {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) { window.location.href = '/admin/' + _slug + '/login'; return }
      const p = await res.json()

      document.getElementById('form-loading')!.classList.add('hidden')
      document.getElementById('product-form')!.classList.remove('hidden');
      (document.getElementById('name') as HTMLInputElement).value = p.name;
      (document.getElementById('description') as HTMLTextAreaElement).value = p.description || '';
      (document.getElementById('price') as HTMLInputElement).value = (p.priceCents / 100).toFixed(2);
      (document.getElementById('compare_price') as HTMLInputElement).value = p.compareAtPriceCents ? (p.compareAtPriceCents / 100).toFixed(2) : '';
      (document.getElementById('stock') as HTMLInputElement).value = p.stock;
      (document.getElementById('status') as HTMLSelectElement).value = p.status;
      (document.getElementById('image_url') as HTMLInputElement).value = p.imageUrl || '';
      (document.getElementById('seo_title') as HTMLInputElement).value = p.seoTitle || '';
      (document.getElementById('seo_description') as HTMLTextAreaElement).value = p.seoDescription || ''

      if (p.imageUrl) {
        const preview = document.getElementById('image-preview')!
        preview.classList.remove('hidden');
        (document.getElementById('preview-img') as HTMLImageElement).src = p.imageUrl
      }

      if (p.variantOptions?.length > 0) {
        for (const opt of p.variantOptions) {
          options.push({ group: opt.groupName, value: opt.value })
        }
        renderVariants()
      }
    } catch {
      document.getElementById('form-loading')!.textContent = 'Failed to load product.'
    }
  }

  loadProduct()

  document.getElementById('upload-btn')?.addEventListener('click', () => {
    document.getElementById('file-input')?.click()
  })

  document.getElementById('file-input')?.addEventListener('change', async () => {
    const input = document.getElementById('file-input') as HTMLInputElement
    const file = input.files?.[0]
    if (!file) return
    const token = localStorage.getItem('vkrama_admin_token')
    const formData = new FormData()
    formData.append('file', file)
    formData.append('folder', 'products')
    const btn = document.getElementById('upload-btn') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = 'Uploading...'
    try {
      const res = await fetch('/api/admin/upload', {
        method: 'POST',
        headers: { Authorization: `Bearer ${token}` },
        body: formData,
      })
      const data = await res.json()
      if (res.ok && data.url) {
        (document.getElementById('image_url') as HTMLInputElement).value = data.url
        const preview = document.getElementById('image-preview')!
        preview.classList.remove('hidden')
        ;(document.getElementById('preview-img') as HTMLImageElement).src = data.url
      } else {
        (window as any).showToast?.(data.error || 'Upload failed', 'error')
      }
    } catch {
      (window as any).showToast?.('Upload failed', 'error')
    } finally {
      btn.disabled = false
      btn.textContent = 'Upload'
      input.value = ''
    }
  })

  document.getElementById('product-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const token = localStorage.getItem('vkrama_admin_token')
    const getVal = (id: string) => (document.getElementById(id) as HTMLInputElement).value

    const payload = {
      name: getVal('name'),
      description: getVal('description'),
      price: parseFloat(getVal('price')),
      compareAtPrice: getVal('compare_price') ? parseFloat(getVal('compare_price')) : null,
      stock: parseInt(getVal('stock')),
      status: getVal('status'),
      imageUrl: getVal('image_url') || null,
      seoTitle: getVal('seo_title') || null,
      seoDescription: getVal('seo_description') || null,
      variantOptions: options,
    }

    try {
      const res = await fetch(`/api/admin/products/${productId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify(payload),
      })
      if (res.ok) {
        (window as any).showToast?.('Product updated', 'success')
        setTimeout(() => { window.location.href = '/admin/' + _slug + '/products' }, 500)
      } else {
        const data = await res.json()
        const errorEl = document.getElementById('error-msg')!
        errorEl.textContent = data.error || 'Update failed'
        errorEl.classList.remove('hidden')
      }
    } catch {
      const errorEl = document.getElementById('error-msg')!
      errorEl.textContent = 'Network error'
      errorEl.classList.remove('hidden')
    }
  })

  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    if (!confirm('Delete this product? This cannot be undone.')) return
    const token = localStorage.getItem('vkrama_admin_token')
    try {
      const res = await fetch(`/api/admin/products/${productId}`, {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.ok) {
        (window as any).showToast?.('Product deleted', 'success')
        setTimeout(() => { window.location.href = '/admin/' + _slug + '/products' }, 500)
      }
      else (window as any).showToast?.('Delete failed', 'error')
    } catch { (window as any).showToast?.('Delete failed', 'error') }
  })
</script>
