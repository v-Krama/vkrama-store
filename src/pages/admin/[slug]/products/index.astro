---
import Admin from '../../../../layouts/Admin.astro'

const { slug } = Astro.params
---

<Admin title="Products">
  <div class="mb-6 flex items-center justify-between">
    <p id="product-count" class="text-sm text-surface-500">Loading...</p>
    <a href={"/admin/" + slug + "/products/new"} class="btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
      Add Product
    </a>
  </div>
  <div id="products-table"></div>
</Admin>

<script define:vars={{ slug }}>
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  async function loadProducts() {
    const token = localStorage.getItem('vkrama_admin_token')
    if (!token) { window.location.href = '/admin/' + slug + '/login'; return }

    try {
      const res = await fetch('/api/admin/products', {
        headers: { Authorization: `Bearer ${token}` },
        signal: AbortSignal.timeout(15000),
      })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const products = await res.json()
      document.getElementById('product-count')!.textContent = `${products.length} products`

      const container = document.getElementById('products-table')!
      if (!Array.isArray(products) || products.length === 0) {
        container.innerHTML = `<div class="card p-8 text-center text-surface-500">No products yet. <a href="/admin/${slug}/products/new" class="text-brand-600 font-medium">Add one</a></div>`
        return
      }

      const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      const statusBadge = (status: string) => {
        const map: Record<string, string> = { active: 'badge-green', draft: 'badge-yellow', archived: 'badge-gray' }
        return `<span class="${map[status] || 'badge-gray'}">${e(status)}</span>`
      }

      let html = '<div class="card overflow-hidden"><table class="w-full text-sm"><thead><tr class="bg-surface-50 border-b border-surface-200">'
      html += '<th class="px-4 py-3 text-left font-medium text-surface-600">Product</th>'
      html += '<th class="px-4 py-3 text-left font-medium text-surface-600">Price</th>'
      html += '<th class="px-4 py-3 text-left font-medium text-surface-600">Stock</th>'
      html += '<th class="px-4 py-3 text-left font-medium text-surface-600">Status</th>'
      html += '<th class="px-4 py-3 text-left font-medium text-surface-600">Actions</th>'
      html += '</tr></thead><tbody class="divide-y divide-surface-200">'

      for (const p of products) {
        const safeId = String(p.id).replace(/[^a-zA-Z0-9_-]/g, '')
        html += `<tr class="hover:bg-brand-50 transition-colors cursor-pointer" onclick="window.location='/admin/' + slug + '/products/${safeId}'">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              ${p.imageUrl ? `<img src="${p.imageUrl}" alt="${e(String(p.name))}" class="w-10 h-10 rounded-lg object-cover bg-surface-100" />` : '<div class="w-10 h-10 rounded-lg bg-surface-100 flex items-center justify-center text-surface-300"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>'}
              <span class="font-medium text-surface-900">${e(String(p.name))}</span>
            </div>
          </td>
          <td class="px-4 py-3 font-semibold">${fp(p.priceCents)}</td>
          <td class="px-4 py-3 text-surface-700">${p.stock}</td>
          <td class="px-4 py-3">${statusBadge(p.status)}</td>
          <td class="px-4 py-3">
            <a href="/admin/${slug}/products/${safeId}" class="text-brand-600 hover:text-brand-700 text-sm font-medium" onclick="event.stopPropagation()">Edit</a>
          </td>
        </tr>`
      }
      html += '</tbody></table></div>'
      container.innerHTML = html
    } catch {
      document.getElementById('product-count')!.textContent = 'Failed to load'
      document.getElementById('products-table')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load products.</div>'
    }
  }
  loadProducts()
</script>
