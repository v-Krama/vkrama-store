---
import Admin from '../../../../layouts/Admin.astro'

const { slug } = Astro.params
---

<Admin title="Orders">
  <div class="flex gap-2 mb-6 flex-wrap" id="status-filters">
    <a href={"/admin/" + slug + "/orders"} class="btn-secondary btn-sm">All</a>
    <a href={"/admin/" + slug + "/orders?status=pending"} class="btn-secondary btn-sm">Pending</a>
    <a href={"/admin/" + slug + "/orders?status=awaiting_payment"} class="btn-secondary btn-sm">Awaiting Payment</a>
    <a href={"/admin/" + slug + "/orders?status=paid"} class="btn-secondary btn-sm">Paid</a>
    <a href={"/admin/" + slug + "/orders?status=processing"} class="btn-secondary btn-sm">Processing</a>
    <a href={"/admin/" + slug + "/orders?status=shipped"} class="btn-secondary btn-sm">Shipped</a>
    <a href={"/admin/" + slug + "/orders?status=delivered"} class="btn-secondary btn-sm">Delivered</a>
    <a href={"/admin/" + slug + "/orders?status=cancelled"} class="btn-secondary btn-sm">Cancelled</a>
  </div>
  <div id="orders-table">
    <div class="card p-8 text-center text-surface-500">
      <div class="w-6 h-6 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
      Loading...
    </div>
  </div>
</Admin>

<script define:vars={{ slug }}>
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  async function loadOrders() {
    const token = localStorage.getItem('vkrama_admin_token')
    if (!token) { window.location.href = '/admin/' + slug + '/login'; return }
    const status = new URLSearchParams(window.location.search).get('status') || ''

    try {
      const url = status ? `/api/admin/orders?status=${status}` : '/api/admin/orders'
      const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const orders = await res.json()
      const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      const container = document.getElementById('orders-table')!

      if (!Array.isArray(orders) || orders.length === 0) {
        container.innerHTML = '<div class="card p-8 text-center text-surface-500">No orders found.</div>'
        return
      }

      const statusBadge = (s: string) => {
        const map: Record<string, string> = {
          delivered: 'badge-green', cancelled: 'badge-red', paid: 'badge-blue',
          processing: 'badge-purple', shipped: 'badge-blue',
          pending: 'badge-yellow', awaiting_payment: 'badge-yellow',
        }
        return `<span class="${map[s] || 'badge-gray'}">${e(s.replace('_', ' '))}</span>`
      }

      let html = '<div class="card overflow-hidden"><table class="w-full text-sm"><thead><tr class="bg-surface-50 border-b border-surface-200"><th class="px-4 py-3 text-left font-medium text-surface-600">Order</th><th class="px-4 py-3 text-left font-medium text-surface-600">Customer</th><th class="px-4 py-3 text-left font-medium text-surface-600">Total</th><th class="px-4 py-3 text-left font-medium text-surface-600">Payment</th><th class="px-4 py-3 text-left font-medium text-surface-600">Status</th><th class="px-4 py-3 text-left font-medium text-surface-600">Date</th></tr></thead><tbody class="divide-y divide-surface-200">'

      for (const o of orders) {
        const safeId = String(o.id).replace(/[^a-zA-Z0-9_-]/g, '')
        html += `<tr class="hover:bg-brand-50 cursor-pointer transition-colors" onclick="window.location='/admin/' + slug + '/orders/${safeId}'">
          <td class="px-4 py-3 font-mono text-xs text-surface-500">#${String(o.id).slice(-8)}</td>
          <td class="px-4 py-3 text-surface-700">${e(String(o.email))}</td>
          <td class="px-4 py-3 font-semibold text-surface-900">${fp(o.totalCents)}</td>
          <td class="px-4 py-3 text-xs text-surface-500">${e(String(o.paymentMethod || '—'))}</td>
          <td class="px-4 py-3">${statusBadge(o.status)}</td>
          <td class="px-4 py-3 text-sm text-surface-500">${new Date(o.createdAt).toLocaleDateString()}</td>
        </tr>`
      }
      html += '</tbody></table></div>'
      container.innerHTML = html
    } catch {
      document.getElementById('orders-table')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load.</div>'
    }
  }
  loadOrders()
</script>
