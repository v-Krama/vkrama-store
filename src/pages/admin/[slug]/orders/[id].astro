---
import Admin from '../../../../layouts/Admin.astro'

const { slug } = Astro.params
---

<Admin title="Order Detail">
  <a href={"/admin/" + slug + "/orders"} class="text-sm text-brand-600 hover:underline mb-4 inline-block">&larr; Back to Orders</a>
  <div id="order-content">
    <div class="card p-8 text-center text-surface-500">
      <div class="w-6 h-6 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
      Loading order...
    </div>
  </div>
</Admin>

<script define:vars={{ slug }}>
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`
  const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  const orderId = window.location.pathname.split('/').pop()

  async function loadOrder() {
    const token = localStorage.getItem('vkrama_admin_token')
    try {
      const res = await fetch(`/api/admin/orders/${orderId}`, {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) { window.location.href = '/admin/' + slug + '/login'; return }
      const o = await res.json()
      const container = document.getElementById('order-content')!

      const statusClass = (s: string) => {
        const map: Record<string, string> = {
          delivered: 'badge-green', cancelled: 'badge-red', paid: 'badge-blue',
          processing: 'badge-purple', shipped: 'badge-blue',
          pending: 'badge-yellow', awaiting_payment: 'badge-yellow',
        }
        return map[s] || 'badge-gray'
      }

      const statuses = ['pending', 'awaiting_payment', 'paid', 'processing', 'shipped', 'delivered', 'cancelled']
      const statusOpts = statuses.map((s) =>
        `<option value="${s}" ${s === o.status ? 'selected' : ''}>${e(s.replace('_', ' '))}</option>`
      ).join('')

      let itemsHtml = ''
      for (const item of o.items || []) {
        itemsHtml += `<div class="flex items-center justify-between py-3 border-b border-surface-100 last:border-0">
          <div class="flex items-center gap-3">
            ${item.imageUrl ? `<img src="${item.imageUrl}" alt="${e(String(item.name))}" class="w-10 h-10 rounded-lg object-cover bg-surface-100" />` : '<div class="w-10 h-10 rounded-lg bg-surface-100" />'}
            <div>
              <p class="text-sm font-medium text-surface-900">${e(String(item.name))}</p>
              ${item.variantName ? `<p class="text-xs text-surface-500">${e(String(item.variantName))}</p>` : ''}
              <p class="text-xs text-surface-400">Qty: ${item.quantity}</p>
            </div>
          </div>
          <span class="text-sm font-semibold text-surface-900">${fp(item.priceCents * item.quantity)}</span>
        </div>`
      }

      container.innerHTML = `
        <div class="grid lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 space-y-6">
            <div class="card p-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-surface-900">Order #${String(o.id)}</h2>
                <span class="${statusClass(o.status)}">${e(o.status.replace('_', ' '))}</span>
              </div>
              <div class="grid grid-cols-2 gap-4 text-sm">
                <div><span class="text-surface-500">Date</span><p class="font-medium text-surface-900">${new Date(o.createdAt).toLocaleString()}</p></div>
                <div><span class="text-surface-500">Email</span><p class="font-medium text-surface-900">${e(String(o.email))}</p></div>
                ${o.phone ? `<div><span class="text-surface-500">Phone</span><p class="font-medium text-surface-900">${e(String(o.phone))}</p></div>` : ''}
                <div><span class="text-surface-500">Payment</span><p class="font-medium text-surface-900">${e(String(o.paymentMethod || '—'))}</p></div>
              </div>
              <div class="mt-6 pt-4 border-t border-surface-200">
                <label class="label" for="status-select">Update Status</label>
                <div class="flex gap-2">
                  <select id="status-select" class="input flex-1">${statusOpts}</select>
                  <button id="update-status" class="btn-primary btn-sm">Update</button>
                </div>
              </div>
            </div>

            <div class="card p-6">
              <h3 class="font-semibold text-surface-900 mb-4">Items</h3>
              ${itemsHtml || '<p class="text-surface-500 text-sm">No items</p>'}
              <div class="mt-4 pt-4 border-t border-surface-200 space-y-1.5 text-sm">
                <div class="flex justify-between"><span class="text-surface-500">Subtotal</span><span>${fp(o.subtotalCents)}</span></div>
                <div class="flex justify-between"><span class="text-surface-500">Shipping</span><span>${o.shippingCents === 0 ? 'Free' : fp(o.shippingCents)}</span></div>
                <div class="flex justify-between"><span class="text-surface-500">Tax</span><span>${fp(o.taxCents)}</span></div>
                <div class="flex justify-between font-bold text-surface-900 text-base pt-2 border-t border-surface-200 mt-2">
                  <span>Total</span>
                  <span>${fp(o.totalCents)}</span>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-6">
            ${o.shipping_name ? `
            <div class="card p-6">
              <h3 class="font-semibold text-surface-900 mb-3">Shipping Address</h3>
              <div class="text-sm text-surface-600 space-y-0.5">
                <p class="font-medium text-surface-900">${e(String(o.shipping_name))}</p>
                ${o.shipping_phone ? `<p>${e(String(o.shipping_phone))}</p>` : ''}
                <p>${e(String(o.shipping_line1 || ''))}</p>
                ${o.shipping_line2 ? `<p>${e(String(o.shipping_line2))}</p>` : ''}
                <p>${e(String(o.shipping_city || ''))}, ${e(String(o.shipping_state || ''))} ${e(String(o.shipping_postal_code || ''))}</p>
              </div>
            </div>` : `
            <div class="card p-6">
              <h3 class="font-semibold text-surface-900 mb-3">Shipping</h3>
              <p class="text-sm text-surface-500">No shipping information</p>
            </div>`}

            <div class="card p-6">
              <h3 class="font-semibold text-surface-900 mb-3">Order Timeline</h3>
              <div class="space-y-3 text-sm">
                <div class="flex gap-3">
                  <div class="w-2 h-2 rounded-full bg-emerald-500 mt-1.5 shrink-0"></div>
                  <div>
                    <p class="text-surface-900 font-medium">Order placed</p>
                    <p class="text-surface-400 text-xs">${new Date(o.createdAt).toLocaleString()}</p>
                  </div>
                </div>
                ${o.status === 'paid' || o.status === 'processing' || o.status === 'shipped' || o.status === 'delivered' ? `
                <div class="flex gap-3">
                  <div class="w-2 h-2 rounded-full bg-emerald-500 mt-1.5 shrink-0"></div>
                  <div>
                    <p class="text-surface-900 font-medium">Payment received</p>
                    <p class="text-surface-400 text-xs">—</p>
                  </div>
                </div>` : ''}
                ${o.status === 'shipped' || o.status === 'delivered' ? `
                <div class="flex gap-3">
                  <div class="w-2 h-2 rounded-full bg-brand-500 mt-1.5 shrink-0"></div>
                  <div>
                    <p class="text-surface-900 font-medium">Shipped</p>
                    <p class="text-surface-400 text-xs">—</p>
                  </div>
                </div>` : ''}
                ${o.status === 'delivered' ? `
                <div class="flex gap-3">
                  <div class="w-2 h-2 rounded-full bg-emerald-500 mt-1.5 shrink-0"></div>
                  <div>
                    <p class="text-surface-900 font-medium">Delivered</p>
                    <p class="text-surface-400 text-xs">—</p>
                  </div>
                </div>` : ''}
              </div>
            </div>
          </div>
        </div>
      `

      document.getElementById('update-status')?.addEventListener('click', async () => {
        const status = (document.getElementById('status-select') as HTMLSelectElement).value
        const res = await fetch(`/api/admin/orders/${orderId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ status }),
        })
        if (res.ok) location.reload()
        else alert('Update failed')
      })
    } catch {
      document.getElementById('order-content')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load order.</div>'
    }
  }
  loadOrder()
</script>
