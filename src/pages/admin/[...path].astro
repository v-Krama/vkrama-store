---
import AdminApp from '../../components/admin/AdminApp'
---

<script is:inline>
  window.__originalError = window.onerror
  window.onerror = function(msg, url, line, col, err) {
    var d = document.createElement('div')
    d.style.cssText = 'position:fixed;top:0;left:0;right:0;padding:20px;background:#fef2f2;border-bottom:3px solid #ef4444;z-index:9999;font-family:monospace;font-size:13px;white-space:pre-wrap;overflow:auto;max-height:50vh'
    d.textContent = 'ERROR: ' + msg + '\n' + (err && err.stack || '')
    document.body.prepend(d)
    if (window.__originalError) window.__originalError(msg, url, line, col, err)
  }
  window.addEventListener('unhandledrejection', function(e) {
    var d = document.createElement('div')
    d.style.cssText = 'position:fixed;top:0;left:0;right:0;padding:20px;background:#fef2f2;border-bottom:3px solid #ef4444;z-index:9999;font-family:monospace;font-size:13px;white-space:pre-wrap;overflow:auto;max-height:50vh'
    d.textContent = 'PROMISE ERROR: ' + (e.reason && e.reason.stack || e.reason || 'Unknown')
    document.body.prepend(d)
  })
</script>

<AdminApp client:only="react" />
