---
import Base from '../../../layouts/Base.astro'
---
<Base title="Order Detail">
  <div class="relative min-h-screen bg-surface-50/50">
    <div class="container-page py-8 lg:py-12">
      <div class="max-w-3xl mx-auto">
        <a href="/account/orders" class="inline-flex items-center gap-1.5 text-sm text-brand-600 hover:text-brand-700 font-medium mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7 7l-7-7 7-7"/></svg>
          Back to Orders
        </a>
        <div id="order-detail">
          <div class="rounded-2xl bg-white border border-surface-200 p-6">
            <div class="animate-pulse space-y-4">
              <div class="flex justify-between">
                <div class="space-y-2">
                  <div class="h-5 w-40 bg-surface-200 rounded-lg"></div>
                  <div class="h-3 w-28 bg-surface-100 rounded-lg"></div>
                </div>
                <div class="h-6 w-20 bg-surface-200 rounded-full"></div>
              </div>
              <div class="h-20 bg-surface-100 rounded-xl"></div>
              <div class="space-y-3">
                <div class="h-12 bg-surface-100 rounded-lg"></div>
                <div class="h-12 bg-surface-100 rounded-lg"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const e = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  const STATUS_STEPS = [
    { key: 'pending', label: 'Order Placed', icon: '📋' },
    { key: 'confirmed', label: 'Confirmed', icon: '✅' },
    { key: 'processing', label: 'Processing', icon: '⚙️' },
    { key: 'shipped', label: 'Shipped', icon: '🚚' },
    { key: 'delivered', label: 'Delivered', icon: '📦' },
  ]

  const statusIndex = (s) => {
    const map = { pending: 0, confirmed: 1, processing: 2, shipped: 3, delivered: 4, cancelled: -1, refunded: -1 }
    return map[s] ?? 0
  }

  function renderTrackingTimeline(currentStatus) {
    const idx = statusIndex(currentStatus)
    if (idx < 0) return ''

    return `
      <div class="bg-surface-50 rounded-xl p-5 mb-6">
        <h3 class="text-xs font-semibold text-surface-500 uppercase tracking-wider mb-4">Order Progress</h3>
        <div class="flex items-center justify-between relative">
          <div class="absolute top-3 left-0 right-0 h-0.5 bg-surface-200"></div>
          <div class="absolute top-3 left-0 h-0.5 bg-brand-500 transition-all" style="width: ${(idx / (STATUS_STEPS.length - 1)) * 100}%"></div>
          ${STATUS_STEPS.map((step, i) => `
            <div class="relative flex flex-col items-center z-10">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs ${i <= idx ? 'bg-brand-600 text-white' : 'bg-surface-200 text-surface-400'}">
                ${i < idx ? '✓' : i === idx ? step.icon : ''}
              </div>
              <span class="text-[10px] text-surface-500 mt-1.5 text-center whitespace-nowrap ${i === idx ? 'font-semibold text-brand-600' : ''}">${step.label}</span>
            </div>
          `).join('')}
        </div>
      </div>
    `
  }

  function renderShipmentInfo(shipments) {
    if (!shipments || shipments.length === 0) return ''
    return shipments.map(s => `
      <div class="bg-surface-50 rounded-xl p-4 mb-4">
        <h3 class="text-xs font-semibold text-surface-500 uppercase tracking-wider mb-2">Shipment</h3>
        <div class="space-y-1 text-sm">
          ${s.carrier ? `<p><span class="text-surface-500">Carrier:</span> <span class="font-medium text-surface-900">${e(s.carrier)}</span></p>` : ''}
          ${s.trackingNumber ? `<p><span class="text-surface-500">Tracking:</span> <span class="font-mono text-surface-900">${e(s.trackingNumber)}</span></p>` : ''}
          ${s.trackingUrl ? `<a href="${e(s.trackingUrl)}" target="_blank" rel="noopener" class="text-brand-600 hover:text-brand-700 text-sm font-medium inline-flex items-center gap-1">Track Package <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a>` : ''}
          ${s.status ? `<p><span class="text-surface-500">Status:</span> <span class="font-medium text-surface-900">${e(s.status.replace(/_/g, ' '))}</span></p>` : ''}
        </div>
      </div>
    `).join('')
  }

  async function loadOrder() {
    const token = localStorage.getItem('vkrama_token')
    if (!token) { window.location.href = '/auth/login'; return }
    const id = window.location.pathname.split('/').pop()
    try {
      const res = await fetch(`/api/orders/${id}`, { headers: { Authorization: `Bearer ${token}` } })
      if (res.status === 401) { localStorage.removeItem('vkrama_token'); window.location.href = '/auth/login'; return }
      if (res.status === 404) {
        document.getElementById('order-detail')!.innerHTML = '<div class="rounded-2xl bg-white border border-surface-200 p-12 text-center"><p class="text-surface-500">Order not found.</p></div>'
        return
      }
      const order = await res.json()
      const container = document.getElementById('order-detail')!
      const statusClass = order.status === 'delivered' ? 'badge-green' :
                          order.status === 'cancelled' ? 'badge-red' :
                          order.status === 'paid' || order.status === 'processing' ? 'badge-blue' :
                          order.status === 'shipped' ? 'badge-purple' : 'badge-yellow'

      let itemsHtml = ''
      for (const item of order.items || []) {
        itemsHtml += `
          <div class="flex items-center gap-4 py-3 border-b border-surface-100 last:border-0">
            ${item.imageUrl ? `<img src="${item.imageUrl}" alt="${e(String(item.name))}" class="w-14 h-14 rounded-lg object-cover bg-surface-100 ring-1 ring-surface-200/50 shrink-0" loading="lazy" />` : '<div class="w-14 h-14 rounded-lg bg-surface-100 shrink-0 ring-1 ring-surface-200/50" />'}
            <div class="flex-1 min-w-0">
              <p class="font-medium text-surface-900 text-sm">${e(String(item.name))}</p>
              ${item.variantName ? `<p class="text-xs text-surface-500">${e(String(item.variantName))}</p>` : ''}
              <p class="text-xs text-surface-400">Qty: ${item.quantity} &times; ${fp(item.priceCents)}</p>
            </div>
            <p class="font-semibold text-surface-900 text-sm">${fp(item.priceCents * item.quantity)}</p>
          </div>
        `
      }

      container.innerHTML = `
        <div class="rounded-2xl bg-white border border-surface-200 p-6">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-6">
            <div>
              <h2 class="text-lg font-bold text-surface-900">Order #${String(order.id)}</h2>
              <p class="text-sm text-surface-400 mt-0.5">${new Date(order.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
            </div>
            <span class="${statusClass} self-start">${e(order.status.replace(/_/g, ' '))}</span>
          </div>

          ${renderTrackingTimeline(order.status)}
          ${renderShipmentInfo(order.shipments)}

          ${order.shippingName ? `
          <div class="bg-surface-50 rounded-xl p-4 mb-6">
            <h3 class="text-xs font-semibold text-surface-500 uppercase tracking-wider mb-2">Shipping Address</h3>
            <div class="text-sm text-surface-700 space-y-0.5">
              <p class="font-medium">${e(String(order.shippingName))}</p>
              ${order.shippingPhone ? `<p>${e(String(order.shippingPhone))}</p>` : ''}
              <p>${e(String(order.shippingLine1 || ''))}${order.shippingLine2 ? ', ' + e(String(order.shippingLine2)) : ''}</p>
              <p>${e(String(order.shippingCity || ''))}, ${e(String(order.shippingState || ''))} ${e(String(order.shippingPostalCode || ''))}</p>
            </div>
          </div>` : ''}

          <div class="border-t border-surface-200 pt-4">
            <h3 class="font-semibold text-surface-900 mb-3 text-sm uppercase tracking-wider text-surface-500">Items</h3>
            ${itemsHtml || '<p class="text-sm text-surface-500 py-4">No items</p>'}
          </div>

          <div class="border-t border-surface-200 pt-4 mt-4 space-y-1.5 text-sm">
            <div class="flex justify-between text-surface-600"><span>Subtotal</span><span>${fp(order.subtotalCents)}</span></div>
            <div class="flex justify-between text-surface-600"><span>Shipping</span><span>${order.shippingCents === 0 ? '<span class="text-emerald-600 font-medium">Free</span>' : fp(order.shippingCents)}</span></div>
            <div class="flex justify-between text-surface-600"><span>Tax</span><span>${fp(order.taxCents)}</span></div>
            <div class="flex justify-between font-bold text-surface-900 text-base pt-2 border-t border-surface-200 mt-2">
              <span>Total</span><span>${fp(order.totalCents)}</span>
            </div>
          </div>

          <div class="mt-6 pt-4 border-t border-surface-200 flex items-center gap-2 text-xs text-surface-400">
            ${order.paymentMethod === 'qr' ? '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>' : '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>'}
            ${order.paymentMethod === 'qr' ? 'Paid via QR Scan' : 'Cash on Delivery'}
          </div>
        </div>
      `
    } catch {
      document.getElementById('order-detail')!.innerHTML = '<div class="rounded-2xl bg-white border border-red-200 p-8 text-center"><p class="text-red-600 font-medium">Failed to load order</p></div>'
    }
  }
  loadOrder()
</script>
