---
import Base from '../../../layouts/Base.astro'
---

<Base title="Order Detail">
  <div class="container-page py-8">
    <div class="max-w-3xl mx-auto">
      <a href="/account/orders" class="text-sm text-brand-600 hover:underline mb-4 inline-block">&larr; Back to Orders</a>
      <div id="order-detail">
        <div class="card p-6">
          <div class="skeleton-cell w-48 h-6 mb-4"></div>
          <div class="skeleton-cell w-full h-24 rounded-xl mb-4"></div>
          <div class="space-y-2"><div class="skeleton-cell w-full h-12"></div><div class="skeleton-cell w-full h-12"></div><div class="skeleton-cell w-3/4 h-12"></div></div>
          <div class="mt-4 pt-4 border-t border-surface-200"><div class="skeleton-cell w-32 h-4 ml-auto"></div></div>
        </div>
      </div>
    </div>
  </div>
</Base>

  <script>
    const e = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
    const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

    async function loadOrder() {
    const token = localStorage.getItem('vkrama_token')
    if (!token) { window.location.href = '/auth/login'; return }
    const id = window.location.pathname.split('/').pop()
    try {
      const res = await fetch(`/api/orders/${id}`, {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) { localStorage.removeItem('vkrama_token'); window.location.href = '/auth/login'; return }
      if (res.status === 404) {
        document.getElementById('order-detail')!.innerHTML = '<div class="card p-8 text-center"><p class="text-surface-500">Order not found.</p></div>'
        return
      }
      const order = await res.json()
      const container = document.getElementById('order-detail')!
      const statusClass = order.status === 'delivered' ? 'badge-green' :
                          order.status === 'cancelled' ? 'badge-red' :
                          order.status === 'paid' || order.status === 'processing' ? 'badge-blue' :
                          order.status === 'shipped' ? 'badge-purple' : 'badge-yellow'

      let itemsHtml = ''
      for (const item of order.items || []) {
        itemsHtml += `
          <div class="flex items-center gap-4 py-3 border-b border-surface-100 last:border-0">
            ${item.imageUrl ? `<img src="${item.imageUrl}" alt="${e(String(item.name))}" class="w-14 h-14 rounded-lg object-cover bg-surface-100" />` : '<div class="w-14 h-14 rounded-lg bg-surface-100 shrink-0" />'}
            <div class="flex-1 min-w-0">
              <p class="font-medium text-surface-900 text-sm">${e(String(item.name))}</p>
              ${item.variantName ? `<p class="text-xs text-surface-500">${e(String(item.variantName))}</p>` : ''}
              <p class="text-xs text-surface-400">Qty: ${item.quantity} &times; ${fp(item.priceCents)}</p>
            </div>
            <p class="font-semibold text-surface-900 text-sm">${fp(item.priceCents * item.quantity)}</p>
          </div>
        `
      }

      container.innerHTML = `
        <div class="card p-6">
          <div class="flex items-start justify-between mb-6">
            <div>
              <h2 class="text-lg font-semibold text-surface-900">Order #${String(order.id)}</h2>
              <p class="text-sm text-surface-400">${new Date(order.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
            </div>
            <span class="${statusClass}">${e(order.status.replace('_', ' '))}</span>
          </div>

          ${order.shippingName ? `
          <div class="bg-surface-50 rounded-xl p-4 mb-6">
            <h3 class="text-sm font-semibold text-surface-900 mb-2">Shipping Address</h3>
            <div class="text-sm text-surface-600 space-y-0.5">
              <p>${e(String(order.shippingName))}</p>
              ${order.shippingPhone ? `<p>${e(String(order.shippingPhone))}</p>` : ''}
              <p>${e(String(order.shippingLine1 || ''))}</p>
              ${order.shippingLine2 ? `<p>${e(String(order.shippingLine2))}</p>` : ''}
              <p>${e(String(order.shippingCity || ''))}, ${e(String(order.shippingState || ''))} ${e(String(order.shippingPostalCode || ''))}</p>
            </div>
          </div>` : ''}

          <div class="border-t border-surface-200 pt-4">
            <h3 class="font-medium text-surface-900 mb-3">Items</h3>
            ${itemsHtml || '<p class="text-sm text-surface-500">No items</p>'}
          </div>

          <div class="border-t border-surface-200 pt-4 mt-4 space-y-1.5 text-sm">
            <div class="flex justify-between text-surface-600">
              <span>Subtotal</span>
              <span>${fp(order.subtotalCents)}</span>
            </div>
            <div class="flex justify-between text-surface-600">
              <span>Shipping</span>
              <span>${order.shippingCents === 0 ? 'Free' : fp(order.shippingCents)}</span>
            </div>
            <div class="flex justify-between text-surface-600">
              <span>Tax</span>
              <span>${fp(order.taxCents)}</span>
            </div>
            <div class="flex justify-between font-bold text-surface-900 text-base pt-2 border-t border-surface-200 mt-2">
              <span>Total</span>
              <span>${fp(order.totalCents)}</span>
            </div>
          </div>

          ${order.paymentMethod === 'qr' ? `
          <div class="mt-6 pt-4 border-t border-surface-200 text-xs text-surface-400">
            Pay via QR scan
          </div>` : order.paymentMethod === 'cod' ? `
          <div class="mt-6 pt-4 border-t border-surface-200 text-xs text-surface-400">
            Cash on Delivery
          </div>` : ''}
        </div>
      `
    } catch {
      document.getElementById('order-detail')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load order.</div>'
    }
  }
  loadOrder()
</script>
