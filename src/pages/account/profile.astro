---
import Base from '../../layouts/Base.astro'
---
<Base title="My Profile">
  <div class="relative min-h-[80vh] bg-surface-50/50">
    <div class="container-page py-8 lg:py-12">
      <div class="max-w-2xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
          <div>
            <h1 class="text-2xl lg:text-3xl font-bold text-surface-900 tracking-tight">My Profile</h1>
            <p class="text-sm text-surface-500 mt-1">Manage your account information</p>
          </div>
          <div class="flex items-center gap-2">
            <a href="/account/orders" class="btn-secondary btn-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              Orders
            </a>
            <a href="/account/addresses" class="btn-secondary btn-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Addresses
            </a>
          </div>
        </div>

        <div id="profile-content">
          <div class="rounded-2xl bg-white border border-surface-200 p-12 text-center text-surface-500">
            <div class="w-8 h-8 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
            <p class="text-sm">Loading profile...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  function e(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;') }

  async function loadProfile() {
    const container = document.getElementById('profile-content')!
    const token = localStorage.getItem('vkrama_token')
    if (!token) {
      container.innerHTML = '<div class="rounded-2xl bg-white border border-surface-200 p-12 text-center"><p class="text-surface-500 mb-4">You need to sign in to view your profile.</p><a href="/auth/login" class="btn-primary">Sign In</a></div>'
      return
    }

    try {
      const res = await fetch('/api/account/profile', { headers: { Authorization: `Bearer ${token}` } })
      if (res.status === 401) { localStorage.removeItem('vkrama_token'); window.location.href = '/auth/login'; return }
      const data = await res.json()

      if (!data.user) {
        container.innerHTML = '<div class="rounded-2xl bg-white border border-surface-200 p-12 text-center text-red-500">User not found.</div>'
        return
      }

      container.innerHTML = `
        <div class="rounded-2xl bg-white border border-surface-200 p-6 sm:p-8">
          <div class="flex items-center gap-4 mb-6 pb-6 border-b border-surface-100">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white text-xl font-bold shadow-lg shadow-brand-500/20">
              ${(data.user.name || data.user.email || '?')[0].toUpperCase()}
            </div>
            <div>
              <h2 class="font-bold text-surface-900 text-lg">${e(data.user.name || 'Unnamed')}</h2>
              <p class="text-sm text-surface-500">${e(data.user.email || '')}</p>
            </div>
          </div>
          <form id="profile-form" class="space-y-5">
            <div>
              <label class="label" for="name">Name</label>
              <input type="text" id="name" class="input" value="${e(data.user.name || '')}" placeholder="Your full name" />
            </div>
            <div>
              <label class="label" for="email">Email</label>
              <input type="email" id="email" class="input bg-surface-50" value="${e(data.user.email || '')}" disabled />
              <p class="text-xs text-surface-400 mt-1.5">Email cannot be changed</p>
            </div>
            <div>
              <label class="label" for="phone">Phone</label>
              <input type="tel" id="phone" class="input" value="${e(data.user.phone || '')}" placeholder="98XXXXXXXX" />
            </div>
            <p id="profile-msg" class="text-sm hidden"></p>
            <button type="submit" class="btn-primary">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Save Changes
            </button>
          </form>
        </div>

        <div class="rounded-2xl bg-white border border-surface-200 p-6 mt-6">
          <h3 class="font-semibold text-surface-900 mb-1">Account Security</h3>
          <p class="text-sm text-surface-500 mb-4">Manage your password and security settings</p>
          <a href="/account/change-password" class="btn-secondary btn-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Change Password
          </a>
        </div>
      `

      document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
        e.preventDefault()
        const name = (document.getElementById('name') as HTMLInputElement).value
        const phone = (document.getElementById('phone') as HTMLInputElement).value
        const msg = document.getElementById('profile-msg')!
        try {
          const res = await fetch('/api/account/profile', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({ name, phone }),
          })
          const data = await res.json()
          if (res.ok) {
            msg.className = 'text-sm text-emerald-600 font-medium'
            msg.textContent = 'Profile updated successfully'
          } else {
            msg.className = 'text-sm text-red-600'
            msg.textContent = data.error || 'Update failed'
          }
        } catch {
          msg.className = 'text-sm text-red-600'
          msg.textContent = 'Network error'
        }
        msg.classList.remove('hidden')
        setTimeout(() => msg.classList.add('hidden'), 4000)
      })
    } catch {
      container.innerHTML = '<div class="rounded-2xl bg-white border border-red-200 p-8 text-center text-red-600 font-medium">Failed to load profile. <a href="/auth/login" class="underline">Sign in again</a></div>'
    }
  }
  loadProfile()
</script>
