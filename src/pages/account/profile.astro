---
import Base from '../../layouts/Base.astro'
---

<Base title="My Profile">
  <div class="container-page py-8">
    <div class="max-w-2xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-surface-900">My Profile</h1>
          <p class="text-sm text-surface-500 mt-1">Manage your account information</p>
        </div>
        <a href="/account/orders" class="btn-secondary btn-sm">&larr; Orders</a>
      </div>

      <div id="profile-content">
        <div class="card p-8 text-center text-surface-500">
          <div class="w-6 h-6 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
          Loading profile...
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  async function loadProfile() {
    const token = localStorage.getItem('vkrama_token')
    if (!token) { window.location.href = '/auth/login'; return }

    try {
      const res = await fetch('/api/account/profile', {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) { localStorage.removeItem('vkrama_token'); window.location.href = '/auth/login'; return }
      const data = await res.json()
      const container = document.getElementById('profile-content')!

      if (!data.user) {
        container.innerHTML = '<div class="card p-8 text-center text-red-500">User not found.</div>'
        return
      }

      container.innerHTML = `
        <form id="profile-form" class="card p-6 space-y-4">
          <div>
            <label class="label" for="name">Name</label>
            <input type="text" id="name" class="input" value="${e(String(data.user.name || ''))}" />
          </div>
          <div>
            <label class="label" for="email">Email</label>
            <input type="email" id="email" class="input" value="${e(String(data.user.email || ''))}" disabled />
            <p class="text-xs text-surface-400 mt-1">Email cannot be changed</p>
          </div>
          <div>
            <label class="label" for="phone">Phone</label>
            <input type="tel" id="phone" class="input" value="${e(String(data.user.phone || ''))}" placeholder="+1 (555) 000-0000" />
          </div>
          <p id="profile-msg" class="text-sm hidden"></p>
          <button type="submit" class="btn-primary">Save Changes</button>
        </form>

        <div class="card p-6 mt-6">
          <h2 class="font-semibold text-surface-900 mb-2">Account Security</h2>
          <p class="text-sm text-surface-500 mb-4">Manage your password and security settings</p>
          <a href="/account/change-password" class="btn-secondary btn-sm">Change Password</a>
        </div>
      `

      document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
        e.preventDefault()
        const name = (document.getElementById('name') as HTMLInputElement).value
        const phone = (document.getElementById('phone') as HTMLInputElement).value
        const msg = document.getElementById('profile-msg')!

        try {
          const res = await fetch('/api/account/profile', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({ name, phone }),
          })
          const data = await res.json()
          if (res.ok) {
            msg.className = 'text-sm text-emerald-600'
            msg.textContent = 'Profile updated successfully'
          } else {
            msg.className = 'text-sm text-red-600'
            msg.textContent = data.error || 'Update failed'
          }
        } catch {
          msg.className = 'text-sm text-red-600'
          msg.textContent = 'Network error'
        }
        msg.classList.remove('hidden')
      })
    } catch {
      document.getElementById('profile-content')!.innerHTML = '<div class="card p-8 text-center text-red-500">Failed to load profile.</div>'
    }
  }
  loadProfile()
</script>
