---
import Base from '../../layouts/Base.astro'
---

<Base title="My Orders">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-gray-900">My Orders</h1>
      <a href="/auth/logout" class="text-sm text-gray-500 hover:text-red-600">Sign Out</a>
    </div>
    <div id="orders-list">
      <div class="card p-8 text-center text-gray-500">Loading orders...</div>
    </div>
  </div>
</Base>

<script>
  async function loadOrders() {
    const token = localStorage.getItem('vkrama_token')
    if (!token) {
      window.location.href = '/auth/login'
      return
    }
    try {
      const res = await fetch('/api/orders', {
        headers: { Authorization: `Bearer ${token}` },
      })
      if (res.status === 401) {
        localStorage.removeItem('vkrama_token')
        window.location.href = '/auth/login'
        return
      }
      const data = await res.json()
      const container = document.getElementById('orders-list')!
      if (!Array.isArray(data) || data.length === 0) {
        container.innerHTML = '<div class="card p-8 text-center text-gray-500">No orders yet.</div>'
        return
      }
      let html = '<div class="space-y-4">'
      for (const order of data) {
        const statusClass = order.status === 'delivered' ? 'badge-green' :
                           order.status === 'cancelled' ? 'badge-red' :
                           order.status === 'awaiting_payment' ? 'badge-yellow' :
                           order.status === 'paid' || order.status === 'processing' ? 'badge-blue' : 'badge-yellow'
        html += `
          <a href="/account/orders/${order.id}" class="card p-4 block hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-mono text-sm text-gray-500">#${order.id}</p>
                <p class="font-medium text-gray-900">$${(order.totalCents / 100).toFixed(2)}</p>
              </div>
              <div class="text-right">
                <span class="${statusClass}">${order.status}</span>
                <p class="text-xs text-gray-400 mt-1">${new Date(order.createdAt).toLocaleDateString()}</p>
              </div>
            </div>
          </a>
        `
      }
      html += '</div>'
      container.innerHTML = html
    } catch {
      document.getElementById('orders-list')!.innerHTML =
        '<div class="card p-8 text-center text-red-500">Failed to load orders.</div>'
    }
  }
  loadOrders()
</script>
