---
import Base from '../../layouts/Base.astro'
---
<Base title="My Orders" description="View your order history at vkrama.">
  <div class="relative min-h-[80vh] bg-surface-50/50">
    <div class="container-page py-8 lg:py-12">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
          <div>
            <h1 class="text-2xl lg:text-3xl font-bold text-surface-900 tracking-tight">My Orders</h1>
            <p class="text-sm text-surface-500 mt-1">View and track your orders</p>
          </div>
          <div class="flex items-center gap-2">
            <a href="/account/profile" class="btn-secondary btn-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              Profile
            </a>
            <a href="/auth/logout" class="btn-ghost btn-sm text-red-600 hover:text-red-700 hover:bg-red-50">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Sign Out
            </a>
          </div>
        </div>

        <div id="orders-list">
          <div class="rounded-2xl bg-white border border-surface-200 p-12 text-center text-surface-500">
            <div class="w-8 h-8 border-2 border-brand-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
            <p class="text-sm">Loading orders...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const e = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
  const fp = (c) => `Rs. ${(c / 100).toFixed(2)}`

  async function loadOrders() {
    const token = localStorage.getItem('vkrama_token')
    if (!token) { window.location.href = '/auth/login'; return }
    try {
      const res = await fetch('/api/orders', { headers: { Authorization: `Bearer ${token}` } })
      if (res.status === 401) { localStorage.removeItem('vkrama_token'); window.location.href = '/auth/login'; return }
      const data = await res.json()
      const container = document.getElementById('orders-list')!

      if (!Array.isArray(data) || data.length === 0) {
        container.innerHTML = `
          <div class="rounded-2xl bg-white border border-surface-200 p-12 text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-surface-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <p class="text-surface-900 font-semibold mb-1">No orders yet</p>
            <p class="text-surface-500 text-sm mb-6">Start shopping to see your orders here</p>
            <a href="/products" class="btn-primary">Browse Products</a>
          </div>
        `
        return
      }

      let html = '<div class="space-y-3">'
      for (const order of data) {
        const statusClass = order.status === 'delivered' ? 'badge-green' :
                           order.status === 'cancelled' ? 'badge-red' :
                           order.status === 'paid' || order.status === 'processing' ? 'badge-blue' :
                           order.status === 'shipped' ? 'badge-purple' : 'badge-yellow'
        html += `
          <a href="/account/orders/${order.id}" class="flex items-center gap-4 p-4 sm:p-5 rounded-2xl bg-white border border-surface-200 hover:border-surface-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-11 h-11 rounded-xl bg-surface-100 flex items-center justify-center shrink-0 group-hover:bg-brand-50 transition-colors">
              <svg class="w-5 h-5 text-surface-500 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-mono text-xs text-surface-400">#${String(order.id)}</p>
              <p class="font-semibold text-surface-900">${fp(order.totalCents)}</p>
              <p class="text-xs text-surface-400">${new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class="${statusClass}">${e(order.status.replace(/_/g, ' '))}</span>
              <svg class="w-5 h-5 text-surface-300 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        `
      }
      html += '</div>'
      container.innerHTML = html
    } catch {
      document.getElementById('orders-list')!.innerHTML = `
        <div class="rounded-2xl bg-white border border-red-200 p-8 text-center">
          <p class="text-red-600 font-medium">Failed to load orders</p>
          <p class="text-sm text-red-500 mt-1">Please try again or refresh the page</p>
        </div>`
    }
  }
  loadOrders()
</script>
