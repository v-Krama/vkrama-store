---
import Base from '../layouts/Base.astro'
---

<Base title="Server Error">
  <div class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center px-4">
      <div class="text-8xl font-extrabold text-brand-600 mb-4">500</div>
      <h1 class="text-2xl font-bold text-surface-900 mb-2">Something Went Wrong</h1>
      <p class="text-surface-500 mb-8 max-w-md mx-auto">
        An unexpected error occurred. Please try again later.
      </p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </div>
</Base>
